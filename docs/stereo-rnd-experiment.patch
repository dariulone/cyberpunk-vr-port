+// [option-B native True Stereo] SPAWN TEST: create an entRenderToTextureCameraComponent, configure it
+// for a full SHADED right-eye view at eye-res, and attach it to the RENDER-ACTIVE player entity. This
+// probes the one remaining runtime-only unknown (not statically decidable, see memory): does the engine
+// tick/attach a cam placed on the live player -> resolve handle@+0x1E8 / allocate view-pair@+0x268 /
+// keep flag88 active? entRenderToTextureMode={Shaded=0,GBufferOnly=1}; Shaded routes through the full
+// standard render-stage pool (no reduced rtt-stage family unlike the mirror) => this is the equal-quality
+// right-eye vehicle. SAFETY: issues NO engine render/attach call (the deadlock in DriveRTTViewCreate came
+// from a synchronous render-view-create on the script thread; we avoid that entirely). The ONLY state
+// mutation is a single PushBack into player->components, CAPACITY-GUARDED: we append only when
+// size<capacity so the engine's DynArray backing buffer is NOT reallocated (no buffer-swap race). If
+// there is no spare capacity we abort+report rather than risk a realloc while the engine iterates.
+// After running, poll with PollRTTHandle across frames (it scans player comps and finds this cam).
+// Params: w,h = eye render-target resolution (<=0 -> 2048). resrefLo/Hi = optional depot resref into
+// +0x1E0 (0 -> leave default; the in-world Shaded producer self-allocates its RT and needs no resref).
+// Returns: 1 = spawned+appended, 0 = already spawned, negative = failure stage.
+static RED4ext::ent::IComponent* g_spawnedRttCam = nullptr;
+void SpawnRTTCamOnPlayer(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t w = 0, h = 0, resLo = 0, resHi = 0;
+    RED4ext::GetParameter(aFrame, &w);
+    RED4ext::GetParameter(aFrame, &h);
+    RED4ext::GetParameter(aFrame, &resLo);
+    RED4ext::GetParameter(aFrame, &resHi);
+    aFrame->code++;
+    if (w <= 0) w = 2048;
+    if (h <= 0) h = 2048;
+    uint64_t resref = ((uint64_t)(uint32_t)resHi << 32) | (uint32_t)resLo;
+
+    std::ofstream out(VRDiagPath("rttcam_spawn.txt"), std::ios::out | std::ios::trunc);
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1; long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+
+    if (g_spawnedRttCam) {
+        if (out) out << "already spawned cam=0x" << std::hex << (uintptr_t)g_spawnedRttCam << std::dec
+                     << " -- skipping (poll with PollRTTHandle)\n";
+        if (aOut) *aOut = 0; return;
+    }
+
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { if (out) out << "no player\n"; if (aOut) *aOut = -1; return; }
+
+    auto* rtti = RED4ext::CRTTISystem::Get();
+    auto* cls = rtti ? rtti->GetClass("entRenderToTextureCameraComponent") : nullptr;
+    if (!cls) { if (out) out << "GetClass failed\n"; if (aOut) *aOut = -2; return; }
+    auto* inst = cls->CreateInstance(true);
+    if (!inst) { if (out) out << "CreateInstance failed\n"; if (aOut) *aOut = -3; return; }
+    cls->InitializeProperties(inst);
+
+    auto* comp = reinterpret_cast<RED4ext::ent::IComponent*>(inst);
+    uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+
+    // configure: owner, Shaded mode, eye-res, enabled, optional depot resref
+    comp->owner = pe;
+    *reinterpret_cast<uint32_t*>(cp + 0x290) = 0;            // renderingMode = Shaded (full pass-set)
+    *reinterpret_cast<uint32_t*>(cp + 0x258) = (uint32_t)w;  // resolution width
+    *reinterpret_cast<uint32_t*>(cp + 0x25C) = (uint32_t)h;  // resolution height
+    if (resref) *reinterpret_cast<uint64_t*>(cp + 0x1E0) = resref;
+    comp->isEnabled = true;
+
+    uintptr_t subVt = *reinterpret_cast<uintptr_t*>(cp + 0x120);
+    uint32_t flag88 = *reinterpret_cast<uint32_t*>(cp + 0x88);
+    if (out) {
+        out << "exeBase=0x" << std::hex << exeBase << std::dec << "  eye-res " << w << "x" << h
+            << " resref=0x" << std::hex << resref << std::dec << "\n";
+        out << "created comp=0x" << std::hex << cp << " subVt(+0x120)=0x" << subVt
+            << " rva=0x" << (rvaOf(subVt) >= 0 ? rvaOf(subVt) : 0) << std::dec
+            << "  (0x2B03A70=preview producer / 0x307D690=in-world producer)\n";
+        out << "flag88=0x" << std::hex << flag88 << std::dec << "  isEnabled set=1\n";
+        out << "player components size=" << pe->components.Size() << " capacity=" << pe->components.Capacity() << "\n";
+        out.flush();
+    }
+
+    // CAPACITY GUARD: append only if no reallocation is needed (avoid swapping the live backing buffer).
+    if (pe->components.Size() >= pe->components.Capacity()) {
+        if (out) out << "ABORT: no spare capacity -- append would realloc the live array (race risk). "
+                        "Component created+configured but NOT attached. Escalation = engine-thread append.\n";
+        if (aOut) *aOut = -4; return;   // leave g_spawnedRttCam null so a later retry is allowed
+    }
+
+    pe->components.PushBack(RED4ext::Handle<RED4ext::ent::IComponent>(comp));
+    g_spawnedRttCam = comp;
+    if (out) {
+        out << "APPENDED to player->components (no realloc). new size=" << pe->components.Size() << "\n";
+        out << "===> wait a few frames, then run PollRTTHandle() repeatedly. Watch for:\n";
+        out << "     +0x1E8 handle resolved, or +0x268 view-pair alloc, or flag88 staying ATTACHED.\n";
+        out.close();
+    }
+    if (aOut) *aOut = 1;
+}
