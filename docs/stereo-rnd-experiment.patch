+bool InstallViewScheduleHook() {
+    // sub_140952CF4 (per-view scheduler). The MSVC prologue (mov r11,rsp; save rbx/rbp/rsi) is too
+    // common for an AOB (it matched the wrong function and crashed), so resolve by exact RVA and
+    // verify the prologue bytes before patching.
+    if (!g_gameModuleBase) { Log("ViewSchedule hook: game base unknown\n"); return false; }
+    uint8_t* found = reinterpret_cast<uint8_t*>(g_gameModuleBase + 0x952CF4);
+    static const uint8_t kExpectPrologue[15] = {
