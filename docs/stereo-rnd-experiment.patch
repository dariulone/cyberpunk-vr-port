+// [option-C native True Stereo] Read-only: CreateInstance a DynamicTexture, set eye-res,
+// and dump its full object layout (vtable + bytes as ptr/rva) to locate the render-texture
+// sub-pointer + generator field -- the object ResizeDynamicTexture(texMgr,&renderTex,w,h)
+// needs. Zero-risk. Writes dyntex_layout.txt. Returns 1 if created.
+void DumpDynTexLayout(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long rva = (long long)(p - exeBase);
+        return (rva >= 0 && rva < 0x10000000) ? rva : -1;
+    };
+    auto readPtrSafe = [](uintptr_t addr, uintptr_t* outv) -> bool {
+        __try { *outv = *reinterpret_cast<uintptr_t*>(addr); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    std::ofstream out(VRDiagPath("dyntex_layout.txt"), std::ios::out | std::ios::trunc);
+    auto* rtti = RED4ext::CRTTISystem::Get();
+    if (!rtti) { if (aOut) *aOut = -1; return; }
+    auto* dtCls = rtti->GetClass("DynamicTexture");
+    if (!dtCls) { out << "DynamicTexture class NOT found\n"; if (aOut) *aOut = -2; return; }
+    auto* dt = dtCls->CreateInstance(true);
+    if (!dt) { out << "CreateInstance FAILED\n"; if (aOut) *aOut = -3; return; }
+    dtCls->InitializeProperties(dt);
+    auto setU = [&](const char* pn, uint32_t v) {
+        if (auto* p = dtCls->GetProperty(pn)) *reinterpret_cast<uint32_t*>(reinterpret_cast<uintptr_t>(dt) + p->valueOffset) = v;
+    };
+    setU("width", 1280); setU("height", 1152);
+
+    uintptr_t obj = reinterpret_cast<uintptr_t>(dt);
+    out << "DynamicTexture inst=0x" << std::hex << obj << std::dec << "\n";
+
+    // reflected properties with offsets/types
+    out << "\n-- reflected properties --\n";
+    RED4ext::DynArray<RED4ext::CProperty*> props;
+    dtCls->GetProperties(props);
+    for (uint32_t i = 0; i < props.Size(); ++i) {
+        auto* p = props[i];
+        if (!p) continue;
+        const char* tn = (p->type && p->type->GetName().ToString()) ? p->type->GetName().ToString() : "?";
+        out << "  @0x" << std::hex << p->valueOffset << std::dec << " " << (p->name.ToString() ? p->name.ToString() : "?")
+            << " : " << tn << " handle=" << (p->flags.isHandle ? 1 : 0) << "\n";
+    }
+
+    // vtable
+    uintptr_t vt = 0;
+    if (readPtrSafe(obj, &vt)) {
+        out << "\n-- instance vtable rva=0x" << std::hex << (rvaOf(vt) >= 0 ? rvaOf(vt) : 0) << std::dec << " (methods) --\n";
+        for (int i = 0; i < 48; ++i) {
+            uintptr_t fn = 0; if (!readPtrSafe(vt + (uintptr_t)i * 8, &fn) || fn == 0) break;
+            long long r = rvaOf(fn);
+            out << "  [" << i << "] " << (r >= 0 ? "ida=0x" : "0x");
+            out << std::hex << (r >= 0 ? (0x140000000ull + (uintptr_t)r) : fn) << std::dec << (r < 0 ? " (non-module)" : "") << "\n";
+        }
+    }
+
+    // raw bytes 0..0x140 as qword + ptr-rva annotation
+    out << "\n-- instance bytes (qword | ptr-rva) --\n";
+    for (uintptr_t off = 0; off <= 0x140; off += 8) {
+        uintptr_t q = 0; if (!readPtrSafe(obj + off, &q)) break;
+        out << "  +0x" << std::hex << off << ": 0x" << q;
+        long long r = rvaOf(q);
+        if (r >= 0) out << "  (module rva=0x" << r << ")";
+        else if (q > 0x10000 && q < 0x7fffffffffff) {
+            uintptr_t inner = 0; long long ir = -1;
+            if (readPtrSafe(q, &inner)) ir = rvaOf(inner);
+            if (ir >= 0) out << "  (heap obj, vtRva=0x" << ir << ")";
+        }
+        out << std::dec << "\n";
+    }
+    out.close();
+    if (aOut) *aOut = 1;
+}
