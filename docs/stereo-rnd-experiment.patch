+        *reinterpret_cast<uint64_t*>(cp + 0x1E0) = resref;   // depot resref -> auto-loader input
+        *reinterpret_cast<uint64_t*>(cp + 0x1E8) = 0;        // clear handle so sub_1423E7768 fires
+        if (out) out << "comp=0x" << std::hex << cp
+                     << " 1E0 " << before1E0 << "->" << *reinterpret_cast<uint64_t*>(cp + 0x1E0)
