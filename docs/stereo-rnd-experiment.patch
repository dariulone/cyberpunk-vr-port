+// [option-C native True Stereo] Dump the instance vtable + raw bytes of the live
+// entRenderToTextureCameraComponent on the player. This reveals the virtual methods
+// (OnAttach / render-callback) where the C++ driver wires the DynamicTexture target +
+// enables scene render -- the wiring CET/script cannot reach. Writes rttcam_vtable_dump.txt.
+void DumpRTTCamVtable(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+
+    RED4ext::ScriptGameInstance gameInstance;
+    RED4ext::Handle<RED4ext::IScriptable> playerHandle;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &playerHandle, gameInstance);
+    if (!playerHandle) { if (aOut) *aOut = -1; return; }
+    auto* playerEntity = reinterpret_cast<RED4ext::ent::Entity*>(playerHandle.instance);
+    if (!playerEntity) { if (aOut) *aOut = -2; return; }
+
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    const uintptr_t exeIdaBase = 0x140000000ull;
+
+    std::ofstream out(VRDiagPath("rttcam_vtable_dump.txt"), std::ios::out | std::ios::trunc);
+    if (!out.is_open()) { if (aOut) *aOut = -3; return; }
+    out << "exe runtime base=0x" << std::hex << exeBase << std::dec << "  (ida=0x140000000)\n";
+
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long rva = (long long)(p - exeBase);
+        return (rva >= 0 && rva < 0x10000000) ? rva : -1;
+    };
+    auto readPtrSafe = [](uintptr_t addr, uintptr_t* outv) -> bool {
+        __try { *outv = *reinterpret_cast<uintptr_t*>(addr); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    int32_t found = 0;
+    for (auto& componentHandle : playerEntity->components) {
+        auto* component = componentHandle.instance;
+        if (!component) continue;
+        RED4ext::CClass* type = component->GetType();
+        if (!type || !ClassIsA(type, "entRenderToTextureCameraComponent")) continue;
+
+        ++found;
+        uintptr_t comp = reinterpret_cast<uintptr_t>(component);
+        out << "\n==== entRenderToTextureCameraComponent #" << found
+            << " inst=0x" << std::hex << comp << std::dec
+            << " name=" << (component->name.ToString() ? component->name.ToString() : "<null>") << "\n";
+
+        // instance vtable
+        uintptr_t vt = 0;
+        if (readPtrSafe(comp, &vt)) {
+            long long vtRva = rvaOf(vt);
+            out << "  instance vtable @0x" << std::hex << vt << std::dec
+                << " rva=0x" << std::hex << (vtRva >= 0 ? vtRva : 0) << std::dec << "\n";
+            out << "  -- vtable methods (ida = 0x140000000 + rva) --\n";
+            for (int i = 0; i < 80; ++i) {
+                uintptr_t fn = 0;
+                if (!readPtrSafe(vt + (uintptr_t)i * 8, &fn) || fn == 0) break;
+                long long fnRva = rvaOf(fn);
+                if (fnRva < 0) { out << "  [" << i << "] 0x" << std::hex << fn << std::dec << " (non-module)\n"; continue; }
+                out << "  [" << i << "] ida=0x" << std::hex << (exeIdaBase + (uintptr_t)fnRva)
+                    << " rva=0x" << fnRva << std::dec << "\n";
+            }
+        } else {
+            out << "  vtable read FAILED\n";
+        }
+
+        // raw instance bytes around known property offsets (0x80..0x2A0)
