+    // render-capable descriptor. ctor sets generic off_143009280; live render-output uses off_1431A9280.
+    // Swap our +0x98 to the render-capable static descriptor (exeBase + 0x31A9280) before resize.
+    uintptr_t descBefore = 0; readPtr(obj + 0x98, &descBefore);
+    uintptr_t gpuBefore  = 0; readPtr(obj + 0xB0, &gpuBefore);
+    *reinterpret_cast<uintptr_t*>(obj + 0x98) = exeBase + 0x31A9280;   // render-capable descriptor
+    out << "desc+0x98 before=0x" << std::hex << (rvaOf(descBefore) >= 0 ? rvaOf(descBefore) : descBefore)
+        << " -> set rva=0x31A9280   gpu+0xB0 before=0x" << gpuBefore << std::dec << "\n"; out.flush();
+
+    // (3) resolve texMgr and GPU-back via ResizeDynamicTexture (sub_14291A4D4).
+    uintptr_t rendererBase = 0, texMgr = 0;
+    if (!readPtr(exeBase + 0x3427C00, &rendererBase) || !rendererBase) { out << "renderer global empty (not in world?)\n"; if (aOut) *aOut = -3; return; }
+    if (!readPtr(rendererBase + 0x70, &texMgr) || !texMgr) { out << "texMgr slot empty\n"; if (aOut) *aOut = -4; return; }
+    out << "texMgr=0x" << std::hex << texMgr << std::dec << "  calling ResizeDynamicTexture...\n"; out.flush();
+
+    typedef void(__fastcall* ResizeFn)(uint64_t ctx, uint64_t* holder, uint32_t w, uint32_t h, uint8_t flag);
+    ResizeFn resize = reinterpret_cast<ResizeFn>(exeBase + 0x291A4D4);
+    uint64_t holder = obj;
+    bool resizeOk = SehCallResize(resize, texMgr, &holder, (uint32_t)w, (uint32_t)h, (uint8_t)flag);
+    if (!resizeOk) out << "ResizeDynamicTexture THREW\n";
+    // (4) re-read GPU backing slot: if +0xB0 populated, the descriptor swap unblocked allocation.
+    uintptr_t gpuAfter = 0; readPtr(obj + 0xB0, &gpuAfter);
+    out << "gpu+0xB0 after=0x" << std::hex << gpuAfter << std::dec
+        << (gpuAfter ? "  <== GPU BACKING ALLOCATED\n" : "  <== still null (resize did not allocate)\n");
+    out << "resize returned ok=" << (resizeOk ? 1 : 0) << "\n";
+    out << "===END=== (watch RT-diag for a " << w << "x" << h << " cluster)\n";
+    out.flush(); out.close();
+    if (aOut) *aOut = resizeOk ? 1 : -5;
+}
