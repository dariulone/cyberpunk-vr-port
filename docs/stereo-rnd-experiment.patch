+// DynamicTexture/generator is enrolled there, regardless of which entity owns the camera.
+//
+// Mechanism (pure memory reads, SEH-guarded -> cannot crash the engine):
+//   renderer = *(exeBase+0x3427C00);  texMgr = *(renderer+0x70)
+//   1) dump renderer[0..0x200] + texMgr[0..0x600] as qwords (module-rva / heap-vtable annotated)
+//   2) scan both for array triples (ptr, count, capacity) and, for each plausible pointer-array,
+//      follow it and dump the first N elements' vtable RVAs -> the dyntex/generator list shows up
+//      as a cluster of same-vtable heap objects. That gives us the generator class + list offset.
+// Run this with the inventory puppet-preview OPEN so the engine's generator is live & enrolled.
+// Writes rendertex_registry.txt. Returns count of plausible arrays found.
+void DumpRenderTexRegistry(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long rva = (long long)(p - exeBase);
+        return (rva >= 0 && rva < 0x10000000) ? rva : -1;
+    };
+    auto readPtrSafe = [](uintptr_t addr, uintptr_t* outv) -> bool {
+        __try { *outv = *reinterpret_cast<uintptr_t*>(addr); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+    auto readU32Safe = [](uintptr_t addr, uint32_t* outv) -> bool {
+        __try { *outv = *reinterpret_cast<uint32_t*>(addr); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+    // looks-like-a-heap-object: readable pointer whose first qword is a readable module vtable
+    auto vtRvaOf = [&](uintptr_t obj) -> long long {
+        uintptr_t vt = 0;
+        if (obj < 0x10000 || obj > 0x7fffffffffffULL) return -1;
+        if (!readPtrSafe(obj, &vt)) return -1;
+        return rvaOf(vt);
+    };
+
+    std::ofstream out(VRDiagPath("rendertex_registry.txt"), std::ios::out | std::ios::trunc);
+    if (!out.is_open()) { if (aOut) *aOut = -99; return; }
+    out << "exe runtime base=0x" << std::hex << exeBase << std::dec << "  (ida=0x140000000)\n";
+
+    uintptr_t renderer = 0;
+    if (!readPtrSafe(exeBase + 0x3427C00, &renderer) || renderer == 0) {
+        out << "FAIL: renderer global (0x3427C00) empty -- not in world?\n";
+        if (aOut) *aOut = -1; return;
+    }
+    uintptr_t texMgr = 0;
+    if (!readPtrSafe(renderer + 0x70, &texMgr) || texMgr == 0) {
+        out << "FAIL: texMgr slot (renderer+0x70) empty\n";
+        if (aOut) *aOut = -2; return;
+    }
+    out << "renderer=0x" << std::hex << renderer << "  texMgr=0x" << texMgr << std::dec << "\n";
+
+    auto dumpBytes = [&](const char* label, uintptr_t base, uintptr_t lo, uintptr_t hi) {
+        out << "\n-- " << label << " bytes [0x" << std::hex << lo << "..0x" << hi << "] (qword | annotation) --\n" << std::dec;
+        for (uintptr_t off = lo; off <= hi; off += 8) {
+            uintptr_t q = 0;
+            if (!readPtrSafe(base + off, &q)) { out << "  +0x" << std::hex << off << ": <unreadable>\n" << std::dec; break; }
+            out << "  +0x" << std::hex << off << ": 0x" << q;
+            long long r = rvaOf(q);
+            if (r >= 0) out << "  (module rva=0x" << r << ")";
+            else {
+                long long vr = vtRvaOf(q);
+                if (vr >= 0) out << "  (heap obj, vtRva=0x" << vr << " ida=0x" << (0x140000000ull + (uintptr_t)vr) << ")";
+            }
+            out << std::dec << "\n";
+        }
