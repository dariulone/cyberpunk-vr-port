+// [STEREO-SBS] Lazily create the stretch-blit pipeline + two RTV-capable temp
+// targets (full per-eye size). Re-created if the backbuffer format/size changes.
+bool OpenXRManager::EnsureSBSResources(const D3D12_RESOURCE_DESC& sourceDesc) {
+    if (!m_d3dDevice) return false;
+    // 2x-wide mode: per-eye = half source width (full per-eye res, no zoom).
+    // Square mode: per-eye temp = full source width; the half we sample is
+    // stretched to fill it (= horizontal zoom, but stable).
+    const bool sbs2x = GetStereoSBS2xEnabled() != 0;
+    const uint32_t w = sbs2x ? static_cast<uint32_t>(sourceDesc.Width) / 2u
+                             : static_cast<uint32_t>(sourceDesc.Width);
+    const uint32_t h = sourceDesc.Height;
+    const uint32_t fmt = static_cast<uint32_t>(sourceDesc.Format);
+    if (w == 0 || h == 0 || fmt == 0) return false;
+    if (m_sbsPSO && m_sbsFormat == fmt && m_sbsWidth == w && m_sbsHeight == h) return true;
+
+    for (int i = 0; i < 2; ++i) { if (m_sbsTempRT[i]) { m_sbsTempRT[i]->Release(); m_sbsTempRT[i] = nullptr; } }
+
+    if (!m_sbsRootSig) {
