+// [STEREO-SHADER] Walk a DXBC container and log its part fourCCs. 'SHEX'/'SHDR'
+// => SM5.x bytecode (mature asm-level editing toolchain exists, 3Dmigoto-style);
+// 'DXIL' => SM6 (LLVM bitcode, far harder to patch). Decides the whole effort.
+static void DumpDxbcParts(const char* tag, uint32_t idx, const void* blob, SIZE_T len) {
+    const uint8_t* p = reinterpret_cast<const uint8_t*>(blob);
+    if (!p || len < 32) return;
+    if (*reinterpret_cast<const uint32_t*>(p) != 0x43425844) return; // 'DXBC'
+    const uint32_t chunkCount = *reinterpret_cast<const uint32_t*>(p + 28);
+    if (chunkCount > 32 || 32 + chunkCount * 4u > len) return;
+    const uint32_t* offsets = reinterpret_cast<const uint32_t*>(p + 32);
+    char parts[256]; int w = 0;
+    for (uint32_t i = 0; i < chunkCount && w < 230; ++i) {
+        const uint32_t off = offsets[i];
+        if (off + 8 > len) continue;
+        const char* fcc = reinterpret_cast<const char*>(p + off);
+        w += sprintf_s(parts + w, sizeof(parts) - w, "%c%c%c%c ",
+                       fcc[0], fcc[1], fcc[2], fcc[3]);
