+// [Skip Tick TEST] Write the native pause field directly. Chain confirmed by IDA: gameTimeSystem ->
+// sub-object [+0xE8] -> IsPausedState leaf getter 0x1405214bc does `mov eax,[rcx+0x30]; test; setne`,
+// so the pause flag = DWORD at sub-object+0x30 (1=paused/frozen, 0=running). This validates the FREEZE
+// PRIMITIVE for Skip Tick: does setting it stop the sim while VR render + head tracking keep going?
+// CET: VRFreezeOn() / VRFreezeOff(). Returns value written, or <0 on error. SEH-guarded raw writes.
+static int32_t VRWritePauseField(uint32_t value) {
+    auto* sys = GetGameSystem<RED4ext::IScriptable>("gameTimeSystem");
+    if (!sys) return -1;
+    uintptr_t ts = reinterpret_cast<uintptr_t>(sys);
+    uintptr_t sub = 0;
+    __try { sub = *reinterpret_cast<uintptr_t*>(ts + 0xE8); }
+    __except (EXCEPTION_EXECUTE_HANDLER) { return -2; }
+    if (sub < 0x10000000000ull) return -3;
+    __try { *reinterpret_cast<volatile uint32_t*>(sub + 0x30) = value; }
+    __except (EXCEPTION_EXECUTE_HANDLER) { return -4; }
+    return static_cast<int32_t>(value);
+}
+void VRFreezeOn(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    int32_t r = VRWritePauseField(1);
+    if (aOut) *aOut = r;
+}
+void VRFreezeOff(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    int32_t r = VRWritePauseField(0);
+    if (aOut) *aOut = r;
+}
