+// renderingMode=Shaded (+ optional res via the other fn). Logs comp+0x88/+0x1E8 before/after.
+// Tests whether isEnabled alone makes the engine attach/GPU-back the cam while its preview UI is
+// CLOSED -- decisive for whether isEnabled is THE lever or the entity must also be render-active.
+void ForceEnableRTTCameraAt(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
