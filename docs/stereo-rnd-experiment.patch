+// [option-C native True Stereo] FULL PIPELINE: create+GPU-back a render-texture, wire it directly
+// into the RTT-camera's resolved-handle slot (comp+0x1E8, bypassing the depot), then call the engine
+// wiring fn sub_1412BAACC to submit the texture + register the camera in the render system. If it
+// works, the engine renders our forward camera into our texture -> RT-diag shows a unique w x h
+// cluster, and we have a native second view. Returns: 1=wired, negative=stage.
+static bool SehCallWire(void(__fastcall* fn)(uint64_t, uint32_t), uint64_t comp, uint32_t fmt) {
+    __try { fn(comp, fmt); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+void WireRenderTexToCamera(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t w = 0, h = 0, flag = 0;
+    RED4ext::GetParameter(aFrame, &w);
+    RED4ext::GetParameter(aFrame, &h);
+    RED4ext::GetParameter(aFrame, &flag);
+    aFrame->code++;
+    if (w <= 0) w = 1280;
+    if (h <= 0) h = 1152;
+
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1; long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+    auto readPtr = [](uintptr_t a, uintptr_t* o) -> bool {
+        __try { *o = *reinterpret_cast<uintptr_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    std::ofstream out(VRDiagPath("rendertex_wire.txt"), std::ios::out | std::ios::trunc);
+    out << "exeBase=0x" << std::hex << exeBase << std::dec << "  " << w << "x" << h << " flag=" << flag << "\n"; out.flush();
+
+    // (1) create + (2) GPU-back render-texture
+    void* mem = VirtualAlloc(nullptr, 0x400, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
+    if (!mem) { out << "VirtualAlloc FAILED\n"; if (aOut) *aOut = -1; return; }
+    memset(mem, 0, 0x400);
+    g_keepAliveRenderTex.push_back(mem);
+    uintptr_t obj = reinterpret_cast<uintptr_t>(mem);
+    if (!SehCallCtor(reinterpret_cast<void(__fastcall*)(void*)>(exeBase + 0x12A3CC0), mem)) { out << "ctor THREW\n"; if (aOut) *aOut = -2; return; }
+    uintptr_t vt = 0; readPtr(obj, &vt);
+    out << "render-tex obj=0x" << std::hex << obj << " vtRva=0x" << (rvaOf(vt) >= 0 ? rvaOf(vt) : 0) << std::dec << "\n"; out.flush();
+    *reinterpret_cast<uint32_t*>(obj + 0x40) = (uint32_t)w;
+    *reinterpret_cast<uint32_t*>(obj + 0x44) = (uint32_t)h;
+
+    uintptr_t rendererBase = 0, texMgr = 0;
+    if (!readPtr(exeBase + 0x3427C00, &rendererBase) || !rendererBase) { out << "renderer global empty\n"; if (aOut) *aOut = -3; return; }
+    if (!readPtr(rendererBase + 0x70, &texMgr) || !texMgr) { out << "texMgr slot empty\n"; if (aOut) *aOut = -4; return; }
+    uint64_t holder = obj;
+    if (!SehCallResize(reinterpret_cast<void(__fastcall*)(uint64_t, uint64_t*, uint32_t, uint32_t, uint8_t)>(exeBase + 0x291A4D4),
+                       texMgr, &holder, (uint32_t)w, (uint32_t)h, (uint8_t)flag)) { out << "resize THREW\n"; if (aOut) *aOut = -5; return; }
+    out << "GPU-backed via ResizeDynamicTexture\n"; out.flush();
+
+    // (3) find the RTT-camera on the player and wire our texture into comp+0x1E8 (resolved handle).
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { out << "no player\n"; if (aOut) *aOut = -6; return; }
+
+    int wired = 0;
+    for (auto& ch : pe->components) {
+        auto* comp = ch.instance;
+        if (!comp) continue;
+        auto* t = comp->GetType();
+        if (!t || !ClassIsA(t, "entRenderToTextureCameraComponent")) continue;
+        uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+        uint64_t prevHandle = *reinterpret_cast<uint64_t*>(cp + 0x1E8);
+        *reinterpret_cast<uint64_t*>(cp + 0x1E8) = obj;          // resolved handle = our texture (skip depot)
+        *reinterpret_cast<uint8_t*>(cp + 0x8B)   = 1;            // isEnabled
+        *reinterpret_cast<uint32_t*>(cp + 0x258) = (uint32_t)w;  // resolutionWidth
+        *reinterpret_cast<uint32_t*>(cp + 0x25C) = (uint32_t)h;  // resolutionHeight
+        out << "comp=0x" << std::hex << cp << " 0x1E8 prev=0x" << prevHandle << " now=0x" << obj << std::dec << "\n"; out.flush();
+        bool wOk = SehCallWire(reinterpret_cast<void(__fastcall*)(uint64_t, uint32_t)>(exeBase + 0x12BAACC), cp, 1);
+        out << "  sub_1412BAACC wire ok=" << (wOk ? 1 : 0) << "\n"; out.flush();
+        if (wOk) ++wired;
+    }
+    out << "wired " << wired << " camera(s)\n===END=== (watch RT-diag for " << w << "x" << h << ")\n"; out.flush(); out.close();
+    if (aOut) *aOut = wired > 0 ? 1 : -7;
+}
