+// [option-C native True Stereo] MAKE-OR-BREAK smoke test: build a GPU-backed render-texture using
+// the reversed primitives, NO depot resref. (1) ctor sub_1412A3CC0 on a self-allocated zeroed block
+// (it's Ctor(this), caller allocates), (2) set eye-res, (3) GPU-back via ResizeDynamicTexture
+// (sub_14291A4D4) on the verified texMgr handle. First ACTIVE render-internal calls. Object kept
+// alive (leaked) to avoid the orphan-destructor AV. Watch RT-diag for a unique w x h cluster.
+// Returns: 1 if both calls returned, negative = failure stage.
+static std::vector<void*> g_keepAliveRenderTex;   // never freed
+// SEH wrappers must live in their own functions (no C++ object unwinding allowed with __try).
+static bool IsReadableRange(uintptr_t a, size_t n) {
+    if (a < 0x10000 || a > 0x7fffffffffffULL) return false;
+    MEMORY_BASIC_INFORMATION mbi{};
+    if (VirtualQuery(reinterpret_cast<LPCVOID>(a), &mbi, sizeof(mbi)) == 0) return false;
+    if (mbi.State != MEM_COMMIT || (mbi.Protect & PAGE_GUARD)) return false;
+    DWORD prot = mbi.Protect & 0xFF;
+    if (prot == PAGE_NOACCESS) return false;
+    uintptr_t end = reinterpret_cast<uintptr_t>(mbi.BaseAddress) + mbi.RegionSize;
+    return (a + n) <= end;
+}
+static bool SehReadU64(uintptr_t a, uintptr_t* v) {
+    __try { *v = *reinterpret_cast<uintptr_t*>(a); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+static bool SehReadU32(uintptr_t a, uint32_t* v) {
+    __try { *v = *reinterpret_cast<uint32_t*>(a); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+static bool SehReadU16(uintptr_t a, uint16_t* v) {
+    __try { *v = *reinterpret_cast<uint16_t*>(a); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+static bool SehCallCtor(void(__fastcall* ctor)(void*), void* mem) {
+    __try { ctor(mem); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+static bool SehCallResize(void(__fastcall* fn)(uint64_t, uint64_t*, uint32_t, uint32_t, uint8_t),
+                          uint64_t ctx, uint64_t* holder, uint32_t w, uint32_t h, uint8_t flag) {
+    __try { fn(ctx, holder, w, h, flag); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+void SmokeCreateRenderTex(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t w = 0, h = 0, flag = 0;
+    RED4ext::GetParameter(aFrame, &w);
+    RED4ext::GetParameter(aFrame, &h);
+    RED4ext::GetParameter(aFrame, &flag);
+    aFrame->code++;
+    if (w <= 0) w = 1280;
+    if (h <= 0) h = 1152;
+
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1; long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+    auto readPtr = [](uintptr_t a, uintptr_t* o) -> bool {
+        __try { *o = *reinterpret_cast<uintptr_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    std::ofstream out(VRDiagPath("rendertex_smoke.txt"), std::ios::out | std::ios::trunc);
+    out << "exeBase=0x" << std::hex << exeBase << std::dec << "  req " << w << "x" << h << " flag=" << flag << "\n";
+    out.flush();
+
+    // (1) allocate a zeroed block for `this`, then run the ctor.
+    void* mem = VirtualAlloc(nullptr, 0x400, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
+    if (!mem) { out << "VirtualAlloc FAILED\n"; if (aOut) *aOut = -1; return; }
+    memset(mem, 0, 0x400);
+    g_keepAliveRenderTex.push_back(mem);
+    uintptr_t obj = reinterpret_cast<uintptr_t>(mem);
+    out << "this=0x" << std::hex << obj << std::dec << "  calling ctor sub_1412A3CC0...\n"; out.flush();
+
+    typedef void(__fastcall* CtorFn)(void*);
+    CtorFn ctor = reinterpret_cast<CtorFn>(exeBase + 0x12A3CC0);
+    bool ctorOk = SehCallCtor(ctor, mem);
+    if (!ctorOk) out << "ctor THREW\n";
+    out << "ctor returned ok=" << (ctorOk ? 1 : 0) << "\n"; out.flush();
+    if (!ctorOk) { if (aOut) *aOut = -2; return; }
+
+    uintptr_t vt = 0; readPtr(obj, &vt);
+    uint32_t dW = *reinterpret_cast<uint32_t*>(obj + 0x40);
+    uint32_t dH = *reinterpret_cast<uint32_t*>(obj + 0x44);
+    uint32_t fmt = *reinterpret_cast<uint32_t*>(obj + 0x54);
+    out << "after ctor: vtRva=0x" << std::hex << (rvaOf(vt) >= 0 ? rvaOf(vt) : 0) << std::dec
+        << "  defaultWH=" << dW << "x" << dH << " fmt=0x" << std::hex << fmt << std::dec
+        << (rvaOf(vt) == 0x2B1BAA0 ? "  <== render-texture class MATCH\n" : "  <== vtable MISMATCH\n");
