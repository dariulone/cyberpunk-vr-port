+    }
+
+    static const char* kHlsl =
+        "Texture2D src:register(t0); SamplerState smp:register(s0);\n"
+        "cbuffer C:register(b0){float uScale;float uOffset;float2 pad;}\n"
+        "void VSMain(uint id:SV_VertexID,out float4 p:SV_Position,out float2 uv:TEXCOORD0){uv=float2((id<<1)&2,id&2);p=float4(uv*float2(2,-2)+float2(-1,1),0,1);}\n"
+        "float4 PSMain(float4 p:SV_Position,float2 uv:TEXCOORD0):SV_Target{return src.SampleLevel(smp,float2(uv.x*uScale+uOffset,uv.y),0);}\n";
+    ID3DBlob* vs = nullptr; ID3DBlob* ps = nullptr; ID3DBlob* e1 = nullptr; ID3DBlob* e2 = nullptr;
+    const HRESULT hvs = D3DCompile(kHlsl, strlen(kHlsl), "sbs", nullptr, nullptr, "VSMain", "vs_5_0", 0, 0, &vs, &e1);
+    const HRESULT hps = D3DCompile(kHlsl, strlen(kHlsl), "sbs", nullptr, nullptr, "PSMain", "ps_5_0", 0, 0, &ps, &e2);
+    if (FAILED(hvs) || FAILED(hps)) {
+        Log("OpenXRManager: SBS shader compile failed vs=0x%08X ps=0x%08X %s%s\n",
+            (unsigned)hvs, (unsigned)hps,
+            e1 ? (const char*)e1->GetBufferPointer() : "", e2 ? (const char*)e2->GetBufferPointer() : "");
+        if (vs) vs->Release(); if (ps) ps->Release(); if (e1) e1->Release(); if (e2) e2->Release();
+        return false;
+    }
+    if (m_sbsPSO) { m_sbsPSO->Release(); m_sbsPSO = nullptr; }
+    D3D12_GRAPHICS_PIPELINE_STATE_DESC pso{};
+    pso.pRootSignature = m_sbsRootSig;
+    pso.VS = { vs->GetBufferPointer(), vs->GetBufferSize() };
+    pso.PS = { ps->GetBufferPointer(), ps->GetBufferSize() };
+    pso.BlendState.RenderTarget[0].RenderTargetWriteMask = D3D12_COLOR_WRITE_ENABLE_ALL;
+    pso.SampleMask = UINT_MAX;
+    pso.RasterizerState.FillMode = D3D12_FILL_MODE_SOLID;
+    pso.RasterizerState.CullMode = D3D12_CULL_MODE_NONE;
+    pso.DepthStencilState.DepthEnable = FALSE; pso.DepthStencilState.StencilEnable = FALSE;
+    pso.PrimitiveTopologyType = D3D12_PRIMITIVE_TOPOLOGY_TYPE_TRIANGLE;
