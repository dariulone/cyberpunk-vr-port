+    dumpBytes("renderer", renderer, 0x0, 0x200);
+    dumpBytes("texMgr",   texMgr,   0x0, 0x600);
+
+    // Array-triple scan: (ptr, u32 count, u32 capacity) with count<=capacity, count in [1..8192],
+    // ptr a readable heap pointer. For each hit, follow as pointer-array and dump element vtRvas.
+    int32_t arraysFound = 0;
+    auto scanArrays = [&](const char* label, uintptr_t base, uintptr_t lo, uintptr_t hi) {
+        out << "\n==== array-triple scan in " << label << " [0x" << std::hex << lo << "..0x" << hi << "] ====\n" << std::dec;
+        for (uintptr_t off = lo; off <= hi; off += 8) {
+            uintptr_t p = 0;
+            if (!readPtrSafe(base + off, &p)) continue;
+            if (p < 0x10000 || p > 0x7fffffffffffULL) continue;
+            uint32_t count = 0, cap = 0;
+            if (!readU32Safe(base + off + 8, &count)) continue;
+            if (!readU32Safe(base + off + 12, &cap)) continue;
+            if (count == 0 || count > 8192 || cap < count || cap > 65536) continue;
+            // verify the pointer-array: first few elements should be readable heap objects with module vtables
+            long long e0vt = -1, e1vt = -1;
