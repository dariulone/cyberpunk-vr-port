+// [option-C native True Stereo] Decisive crux test: create a DynamicTexture via RTTI
+// CreateInstance, set eye-res, and write it into the RTT-cam component's dynamicTextureRes
+// (+0x1E0). If the engine render-system then renders our component, native true-stereo works
+// without reversing the C++ driver. Returns: 1=assigned, negative=failure stage.
+void TryCreateRTTTarget(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t w = 0, h = 0;
+    RED4ext::GetParameter(aFrame, &w);
+    RED4ext::GetParameter(aFrame, &h);
+    aFrame->code++;
+    if (w <= 0) w = 1024;
+    if (h <= 0) h = 1024;
+
+    std::ofstream out(VRDiagPath("rttcam_target_test.txt"), std::ios::out | std::ios::trunc);
+
+    auto* rtti = RED4ext::CRTTISystem::Get();
+    if (!rtti) { if (aOut) *aOut = -1; return; }
+
+    auto* dtCls = rtti->GetClass("DynamicTexture");
+    if (!dtCls) { if (out) out << "DynamicTexture class NOT found\n"; if (aOut) *aOut = -2; return; }
+
+    auto* dt = dtCls->CreateInstance(true);
+    if (!dt) { if (out) out << "DynamicTexture CreateInstance FAILED\n"; if (aOut) *aOut = -3; return; }
+    dtCls->InitializeProperties(dt);
+    if (out) out << "DynamicTexture instance=0x" << std::hex << reinterpret_cast<uintptr_t>(dt) << std::dec << "\n";
+
+    // set width/height by reflected property name (best-effort)
+    auto setU = [&](const char* pn, uint32_t v) {
+        if (auto* p = dtCls->GetProperty(pn)) {
+            if (out) out << "  set " << pn << " @0x" << std::hex << p->valueOffset << std::dec << " = " << v << "\n";
+            *reinterpret_cast<uint32_t*>(reinterpret_cast<uintptr_t>(dt) + p->valueOffset) = v;
+        } else if (out) out << "  prop " << pn << " NOT found\n";
+    };
+    setU("width", (uint32_t)w);
+    setU("height", (uint32_t)h);
+
+    // find our RTT-cam component on the player and write dt into dynamicTextureRes (+0x1E0)
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { if (out) out << "no player\n"; if (aOut) *aOut = -4; return; }
+
+    int32_t assigned = 0;
+    for (auto& ch : pe->components) {
+        auto* comp = ch.instance;
+        if (!comp) continue;
+        auto* t = comp->GetType();
+        if (!t || !ClassIsA(t, "entRenderToTextureCameraComponent")) continue;
+
+        uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+        // log the resource-ref slot before/after; offset confirmed at +0x1E0 from vtable dump
+        uint64_t before = *reinterpret_cast<uint64_t*>(cp + 0x1E0);
+        *reinterpret_cast<uint64_t*>(cp + 0x1E0) = reinterpret_cast<uint64_t>(dt);
+        uint64_t after = *reinterpret_cast<uint64_t*>(cp + 0x1E0);
+        if (out) out << "comp=0x" << std::hex << cp << " +0x1E0 before=0x" << before
+                     << " after=0x" << after << std::dec << "\n";
+        ++assigned;
+    }
+    if (out) { out << "assigned to " << assigned << " component(s)\n"; out.close(); }
+    if (aOut) *aOut = assigned > 0 ? 1 : -5;
+}
