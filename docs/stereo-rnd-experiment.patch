+                D3D12_RESOURCE_STATE_COMMON, nullptr, IID_PPV_ARGS(&m_sbsTempRT[i])))) return false;
+        D3D12_CPU_DESCRIPTOR_HANDLE rtv = m_sbsRtvHeap->GetCPUDescriptorHandleForHeapStart();
+        rtv.ptr += static_cast<SIZE_T>(i) * m_sbsRtvSize;
+        m_d3dDevice->CreateRenderTargetView(m_sbsTempRT[i], nullptr, rtv);
+    }
+    m_sbsFormat = fmt; m_sbsWidth = w; m_sbsHeight = h;
+    Log("OpenXRManager: SBS resources ready %ux%u fmt=%u\n", w, h, fmt);
+    return true;
+}
