+// [option-C simultaneous] eye-2 producer call wrapped in SEH so a DOWNSTREAM render fault from the 2nd
+// view is caught + logged HERE (this compiled fn has real .pdata) instead of propagating into the
+// unwind-fatal base-5 path that masks the true fault. 4-arg fastcall: producer ptr + the 3 orig args.
+typedef uintptr_t (__fastcall *ProducerFn3)(uintptr_t, uintptr_t, uintptr_t);
+static volatile long g_eye2ProdFaultLogged = 0;
+static uintptr_t g_eye2ProdFaultRip = 0;
+static uintptr_t g_eye2ProdFaultTgt = 0;
+static int Eye2ProdFilter(struct _EXCEPTION_POINTERS* ep) {
+    if (ep && ep->ExceptionRecord) {
+        g_eye2ProdFaultRip = reinterpret_cast<uintptr_t>(ep->ExceptionRecord->ExceptionAddress);
+        if (ep->ExceptionRecord->NumberParameters >= 2)
+            g_eye2ProdFaultTgt = static_cast<uintptr_t>(ep->ExceptionRecord->ExceptionInformation[1]);
+    }
+    return EXCEPTION_EXECUTE_HANDLER;
+}
+extern "C" uintptr_t Eye2ProducerCall(uintptr_t producer, uintptr_t a1, uintptr_t a2, uintptr_t a3) {
+    __try {
+        return reinterpret_cast<ProducerFn3>(producer)(a1, a2, a3);
+    } __except (Eye2ProdFilter(GetExceptionInformation())) {
+        if (InterlockedCompareExchange(&g_eye2ProdFaultLogged, 1, 0) == 0) {
+            uintptr_t rip = g_eye2ProdFaultRip;
+            uintptr_t rva = (rip >= g_gameModuleBase && rip < g_gameModuleBase + 0x6000000)
+                            ? rip - g_gameModuleBase : 0;
+            Log("[EYE2-PROD-FAULT] caught downstream fault from 2nd producer call: rip=0x%llX rva=0x%llX target=0x%llX\n",
+                (unsigned long long)rip, (unsigned long long)rva, (unsigned long long)g_eye2ProdFaultTgt);
+        }
+        return 0;
+    }
+}
