+    int found = 0;
+    for (uintptr_t q = sp; sp && q < sp + 0x1200 && found < 40; q += sizeof(uintptr_t)) {
+        uintptr_t a = 0;
+        if (!ReadPtrSafe(q, &a)) continue;
+        if (!IsInGameModule(a)) continue;
+        if (!IsCallReturnSite(a)) continue;
+        Log("    ida=0x%llX rva=0x%llX\n",
+            static_cast<unsigned long long>(0x140000000ULL + (a - g_gameModuleBase)),
+            static_cast<unsigned long long>(a - g_gameModuleBase));
+        ++found;
+    }
+    Log("==== END CRASH ====\n");
+    return EXCEPTION_CONTINUE_SEARCH; // let the game's handler run
