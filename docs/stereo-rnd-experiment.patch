+// [option-C native True Stereo] Directly invoke the engine auto-loader sub_1423E7768(comp, 0) on our
+// camera, instead of waiting for a component tick that a script-added (non-attached) component may
+// never get. The auto-loader: if(!comp[0x1E8] && comp[0x1E0]) load resref -> LoadDynamicTexture. We
+// ensure +0x1E0=resref, +0x1E8=0, then call it SEH-guarded and dump whether +0x1E8 resolved a handle.
+typedef int64_t(__fastcall* AutoLoadFn)(uintptr_t, int);
+static bool SehCallAutoLoad(AutoLoadFn fn, uintptr_t comp, int a2) {
+    __try { fn(comp, a2); return true; } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+void DriveRTTCameraLoad(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t loIn = 0, hiIn = 0;
+    RED4ext::GetParameter(aFrame, &loIn);
+    RED4ext::GetParameter(aFrame, &hiIn);
+    aFrame->code++;
+    uint64_t resref = 0xD55FB557EAEBA05Bull;
+    if (loIn != 0 || hiIn != 0) resref = ((uint64_t)(uint32_t)hiIn << 32) | (uint32_t)loIn;
+
+    std::ofstream out(VRDiagPath("rttcam_drive.txt"), std::ios::out | std::ios::trunc);
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    AutoLoadFn autoLoad = reinterpret_cast<AutoLoadFn>(exeBase + 0x23E7768);
+
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { if (out) out << "no player\n"; if (aOut) *aOut = -1; return; }
+
+    int32_t driven = 0;
+    for (auto& ch : pe->components) {
+        auto* comp = ch.instance;
+        if (!comp) continue;
+        auto* t = comp->GetType();
+        if (!t || !ClassIsA(t, "entRenderToTextureCameraComponent")) continue;
+        uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+        *reinterpret_cast<uint64_t*>(cp + 0x1E0) = resref;
+        *reinterpret_cast<uint64_t*>(cp + 0x1E8) = 0;
+        uint64_t h_before = *reinterpret_cast<uint64_t*>(cp + 0x1E8);
+        bool ok = SehCallAutoLoad(autoLoad, cp, 0);
+        uint64_t h_after = *reinterpret_cast<uint64_t*>(cp + 0x1E8);
+        if (out) out << "comp=0x" << std::hex << cp << " autoLoad ok=" << std::dec << (ok?1:0)
+                     << std::hex << " +0x1E8 before=0x" << h_before << " after=0x" << h_after << std::dec << "\n";
+        ++driven;
+    }
