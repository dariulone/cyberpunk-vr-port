+                    << " ida=0x" << (0x140000000ull + (subvt - exeBase)) << std::dec << "\n";
+                if (readQSafe(subvt + 0xD8, &getter) && getter) {
+                    out << "  getter[vt+0xD8] = 0x" << std::hex << getter
+                        << " ida=0x" << (0x140000000ull + (getter - exeBase)) << std::dec << "\n  getter bytes: ";
+                    for (int b = 0; b < 40; ++b) {
