+            eb.Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION; eb.Transition.pResource = f->texture;
+            eb.Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
