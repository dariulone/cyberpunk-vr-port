+// [option-C simultaneous] PRODUCER native AddView via call-site patch. See forward-decl comment.
+// At 0x212843: rcx=builder (rdi), rdx=&desc (lea [rsp+0x20]); engine already gated insert on key==0.
+// We redirect the E8 to a trampoline that (1) always issues eye-1 insert, (2) when g_dualView is armed
+// issues an identical eye-2 insert (count++ in g_dualViewCount), then jmps back to 0x212848. Patching
+// a mid-body CALL keeps every prologue + .pdata intact (no base-5 unwind crash); sub_140212780 runs
+// unpatched. Only volatile regs are touched (same as the original call would); rbx/rsi are saved/restored.
+bool InstallViewInsertCallSiteHook() {
+    if (!g_gameModuleBase) { Log("ViewInsert call-site hook: game base unknown\n"); return false; }
+    uint8_t* site = reinterpret_cast<uint8_t*>(g_gameModuleBase + 0x212843);
+    static const uint8_t kExpectCall[5] = { 0xE8, 0x38, 0xFF, 0xFF, 0xFF }; // call sub_140212780
+    if (!IsReadableAddressRange(reinterpret_cast<uintptr_t>(site), sizeof(kExpectCall)) ||
+        memcmp(site, kExpectCall, sizeof(kExpectCall)) != 0) {
+        Log("ViewInsert call-site hook: call-bytes mismatch at %p (rva=0x212843); aborting\n", site);
+        return false;
+    }
+    const uintptr_t insertFn = g_gameModuleBase + 0x212780;
+    const uintptr_t jmpBack  = g_gameModuleBase + 0x212848;   // site + 5
+    void* tramp = AllocateTrampoline(site, 256);
+    if (!tramp) return false;
+    uint8_t* code = static_cast<uint8_t*>(tramp);
+    int pos = 0;
+    auto emit = [&](std::initializer_list<uint8_t> b){ for (uint8_t x : b) code[pos++] = x; };
+
+    emit({0x53});                                     // push rbx
+    emit({0x56});                                     // push rsi   (rsp now 16-aligned)
+    emit({0x48,0x8B,0xD9});                           // mov rbx,rcx   (builder)
+    emit({0x48,0x8B,0xF2});                           // mov rsi,rdx   (&desc)
+    // --- eye-1 (always) ---
+    emit({0x48,0x83,0xEC,0x20});                      // sub rsp,0x20  (shadow; keeps 16-align)
+    emit({0x48,0x8B,0xCB});                           // mov rcx,rbx
+    emit({0x48,0x8B,0xD6});                           // mov rdx,rsi
+    WriteMovRaxImm64(code, pos, insertFn);            // mov rax, sub_140212780
+    emit({0xFF,0xD0});                                // call rax
+    emit({0x48,0x83,0xC4,0x20});                      // add rsp,0x20
+    // --- armed? ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_dualView)); // mov rax,&flag
+    emit({0x83,0x38,0x00});                           // cmp dword [rax],0
+    emit({0x74,0x27});                                // je .done  (skip 0x27-byte armed block)
+    // --- eye-2 (armed): 2nd native insert => slot 1 ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_dualViewCount)); // mov rax,&count
+    emit({0xF0,0xFF,0x00});                           // lock inc dword [rax]
+    emit({0x48,0x83,0xEC,0x20});                      // sub rsp,0x20
+    emit({0x48,0x8B,0xCB});                           // mov rcx,rbx
+    emit({0x48,0x8B,0xD6});                           // mov rdx,rsi
+    WriteMovRaxImm64(code, pos, insertFn);            // mov rax, sub_140212780
+    emit({0xFF,0xD0});                                // call rax
+    emit({0x48,0x83,0xC4,0x20});                      // add rsp,0x20
+    // .done:
+    emit({0x5E});                                     // pop rsi
+    emit({0x5B});                                     // pop rbx
+    emit({0xFF,0x25});                                // jmp qword ptr [rip+0]
+    *reinterpret_cast<int32_t*>(code + pos) = 0; pos += 4;
+    *reinterpret_cast<uint64_t*>(code + pos) = static_cast<uint64_t>(jmpBack); pos += 8;
+
+    uint8_t patch[5];
+    patch[0] = 0xE9;
+    *reinterpret_cast<int32_t*>(patch + 1) = static_cast<int32_t>(code - (site + 5));
+    if (!PatchCodeSafely(site, patch, 5)) {
+        Log("ViewInsert call-site hook: safe-patch failed; aborting\n");
+        return false;
+    }
+    Log("ViewInsert call-site hook installed: patched call at %p (rva=0x212843) -> tramp %p (%d bytes)\n",
+        site, tramp, pos);
+    return true;
+}
