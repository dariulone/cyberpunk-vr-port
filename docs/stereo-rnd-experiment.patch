+        if (FAILED(D3D12SerializeRootSignature(&rs, D3D_ROOT_SIGNATURE_VERSION_1, &sig, &err))) {
+            if (err) err->Release(); return false;
+        }
+        const HRESULT hr = m_d3dDevice->CreateRootSignature(0, sig->GetBufferPointer(), sig->GetBufferSize(), IID_PPV_ARGS(&m_sbsRootSig));
+        if (sig) sig->Release(); if (err) err->Release();
