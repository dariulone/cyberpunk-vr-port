+    code[pos++] = 0x5D; code[pos++] = 0x41; code[pos++] = 0x5B; code[pos++] = 0x41; code[pos++] = 0x5A;
+    code[pos++] = 0x41; code[pos++] = 0x59; code[pos++] = 0x41; code[pos++] = 0x58;
+    code[pos++] = 0x5A; code[pos++] = 0x59; code[pos++] = 0x58; code[pos++] = 0x9D;
+    code[pos++] = 0xFF; code[pos++] = 0x25;
+    *reinterpret_cast<int32_t*>(code + pos) = 0; pos += 4;
+    *reinterpret_cast<uint64_t*>(code + pos) = reinterpret_cast<uint64_t>(found + replaceLen); pos += 8;
