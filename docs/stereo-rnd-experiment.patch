+    FILE* f = nullptr;
+    if (fopen_s(&f, "cyberpunkvrport_m0.txt", "rb") != 0 || !f) return;
+    char buf[96]{};
+    const size_t n = fread(buf, 1, sizeof(buf) - 1, f);
+    fclose(f);
+    if (!n) return;
