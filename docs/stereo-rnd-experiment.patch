+    uintptr_t cp = (static_cast<uintptr_t>(static_cast<uint32_t>(hi)) << 32) | static_cast<uint32_t>(lo);
+    if (out) out << "target=0x" << std::hex << cp << std::dec << "\n";
+
+    // module base of Cyberpunk2077.exe for vtable validation
+    uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    uintptr_t expectVt = exeBase + 0x307BFD0;
+
+    uintptr_t vt = 0;
+    if (!SehReadU64(cp, &vt)) {
+        if (out) { out << "EXCEPTION accessing target -- bad address\n"; out.close(); }
+        if (aOut) *aOut = -3;
+        return;
+    }
+    if (out) out << "vt=0x" << std::hex << vt << " expect=0x" << expectVt << std::dec << "\n";
+    if (vt != expectVt) {
+        if (out) { out << "VTABLE MISMATCH -- not an RTT cam, aborting (no write)\n"; out.close(); }
+        if (aOut) *aOut = -2;
+        return;
+    }
+    uintptr_t flagBefore = 0, hBefore = 0;
+    SehReadU64(cp + 0x88, &flagBefore);
+    SehReadU64(cp + 0x1E8, &hBefore);
+    bool ok = SehEnableRttCam(cp);   // renderingMode=Shaded + isEnabled=1
+    uintptr_t flagAfter = 0; SehReadU64(cp + 0x88, &flagAfter);
+    if (out) out << "+0x88 before=0x" << std::hex << flagBefore << " after=0x" << flagAfter
+                 << "  +0x1E8(handle) before=0x" << hBefore << std::dec
+                 << (ok ? "\n" : "  (WRITE FAIL)\n");
+    if (out) { out << "isEnabled set; poll comp+0x1E8 via live-RPM\n"; out.close(); }
+    if (aOut) *aOut = 1;
+}
