+// [option-C native True Stereo] POLL the resolved-handle slot. The depot load triggered by
+// DriveRTTCameraLoad is ASYNC (the +0x1E8 write happens on a job thread a few frames later), so a
+// synchronous read right after the call always shows 0. Call this a few times across frames AFTER
+// driving the load (with inventory/preview OPEN so the resref is registered in the depot). If +0x1E8
+// ever flips non-zero -> resref is valid + async -> native auto-load path works.
+void PollRTTHandle(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(aFrame); RED4EXT_UNUSED_PARAMETER(a4);
+    if (aFrame) aFrame->code++;
+    std::ofstream out(VRDiagPath("rttcam_poll.txt"), std::ios::out | std::ios::app);
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { if (out) out << "no player\n"; if (aOut) *aOut = -1; return; }
+    int32_t found = 0;
+    for (auto& ch : pe->components) {
+        auto* comp = ch.instance;
+        if (!comp) continue;
+        auto* t = comp->GetType();
+        if (!t || !ClassIsA(t, "entRenderToTextureCameraComponent")) continue;
+        uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+        uint64_t h = *reinterpret_cast<uint64_t*>(cp + 0x1E8);
+        uint64_t r = *reinterpret_cast<uint64_t*>(cp + 0x1E0);
+        uint32_t flag88 = *reinterpret_cast<uint32_t*>(cp + 0x88);   // 0x1000003 active vs 0x3 idle
+        uint64_t subVt  = *reinterpret_cast<uint64_t*>(cp + 0x120);  // 0x2B03A70 preview / 0x307D690 in-world
+        uint64_t vp268  = *reinterpret_cast<uint64_t*>(cp + 0x268);  // in-world producer view-pair slot
+        uint64_t vp270  = *reinterpret_cast<uint64_t*>(cp + 0x270);
+        bool attached = (flag88 & 0x01000000u) != 0;
+        if (out) out << "comp=0x" << std::hex << cp << " +0x1E0=0x" << r << " +0x1E8=0x" << h
+                     << " flag88=0x" << flag88 << " subVt=0x" << subVt
+                     << " +0x268/0x270=0x" << vp268 << "/0x" << vp270 << std::dec
+                     << (attached ? " [flag88 ATTACHED]" : " [flag88 idle]")
+                     << (h ? "  <== HANDLE RESOLVED" : (vp268 ? "  <== VIEW-PAIR ALLOC" : "  (still null)")) << "\n";
+        if (h || vp268) ++found;
+    }
+    if (out) out.close();
+    if (aOut) *aOut = found;
+}
