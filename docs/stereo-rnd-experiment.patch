+        cl->SetGraphicsRootDescriptorTable(0, srvGpu);
+        // [STEREO-SBS] Normal: eye0=left half (uScale .5 off 0), eye1=right half
+        // (off .5). DEBUG (flag 0x200): show the WHOLE backbuffer in both eyes
+        // (uScale 1, off 0) so the real layout can be described from the HMD.
+        const bool sbsDebugFull = GetStereoSBSDebugFull() != 0;
+        float c[4];
+        c[0] = sbsDebugFull ? 1.0f : 0.5f;
+        c[1] = sbsDebugFull ? 0.0f : (eye ? 0.5f : 0.0f);
+        c[2] = 0.0f; c[3] = 0.0f;
