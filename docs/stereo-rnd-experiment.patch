+    const uint64_t mask = _strtoui64(buf, &end, 16);
+    uint32_t flags = 0;
+    char* end2 = end;
+    if (end && *end) flags = static_cast<uint32_t>(strtoul(end, &end2, 16));
+    if (end2 && *end2) {
