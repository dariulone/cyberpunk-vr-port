+// [simultaneous eye-2 CLONE] The plain dual-submit (same *a5 twice) crashed downstream because FrameGraph
+// stamps per-build state into the handle identity; two builds on one handle clobber each other. The RT is
+// auto-allocated by FrameGraph per DISTINCT handle (proven: inventory preview gets its own RT). So eye-2 is
+// issued with a SHALLOW CLONE of the handle: a fresh heap copy (distinct identity) => FrameGraph allocates it
+// a fresh RT, and the build owns its own handle to stamp. Sub-objects stay shared (read-only view spec).
+// Refcount pinned high so the engine never frees our heap allocation (intentional leak for the test window).
+typedef uintptr_t (*FgbSubmitFn)(uintptr_t, uintptr_t, uintptr_t, uintptr_t, uintptr_t*);
+// The view-handle object is larger than the ctor touches: the build reads fields up to at least +0xF88
+// (sub_140219730). Allocate generously and copy a page-safe maximal prefix so every real field is present.
+static const size_t kViewHandleCloneSize = 0x2000;
+
+extern "C" uintptr_t Eye2CloneSubmit(uintptr_t a1, uintptr_t a2, uintptr_t a3, uintptr_t a4, uintptr_t* a5) {
+    if (!a5) return 0;
+    uintptr_t orig = 0;
+    if (!ReadPtrSafe(reinterpret_cast<uintptr_t>(a5), &orig) || !orig) { InterlockedIncrement(&g_eye2CloneFail); return 0; }
+    uintptr_t vt = 0;
+    if (!ReadPtrSafe(orig, &vt) || (vt < g_gameModuleBase) || (vt - g_gameModuleBase) != 0x2AC8688) {
+        InterlockedIncrement(&g_eye2CloneFail); return 0; // not the view-handle class -> skip
+    }
+    void* clone = HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, kViewHandleCloneSize);
+    if (!clone) { InterlockedIncrement(&g_eye2CloneFail); return 0; }
+    // Copy in 0x100 chunks; continue past any unreadable chunk (zero-filled by HEAP_ZERO_MEMORY) so a single
+    // straddling page doesn't truncate later valid fields. Track how many chunks actually copied.
+    size_t copiedBytes = 0, lastGood = 0;
+    for (size_t off = 0; off < kViewHandleCloneSize; off += 0x100) {
+        if (SafeCopyBytes(reinterpret_cast<uint8_t*>(clone) + off,
+                          reinterpret_cast<const uint8_t*>(orig) + off, 0x100)) {
+            copiedBytes += 0x100; lastGood = off + 0x100;
+        }
+    }
+    if (lastGood < 0x1000) {   // must at least cover the field at +0xF88 the build dereferences
+        HeapFree(GetProcessHeap(), 0, clone);
+        InterlockedIncrement(&g_eye2CloneFail); return 0;
+    }
+    if (g_eye2CloneCount == 0) {  // one-shot diagnostic: report clone coverage
+        Log("[EYE2-CLONE] orig=0x%llX clone=0x%llX copiedBytes=0x%llX lastGood=0x%llX\n",
+            (unsigned long long)orig, (unsigned long long)clone,
+            (unsigned long long)copiedBytes, (unsigned long long)lastGood);
+    }
+    // Pin refcount high so engine dec never reaches 0 -> never frees our HeapAlloc'd memory.
+    *reinterpret_cast<volatile long*>(reinterpret_cast<uintptr_t>(clone) + 8) = 0x00100000;
+    // Deep-clone the two dominant per-view sub-objects (class vtRva 0x2E92718) at handle+0x40 and +0x60.
+    // The eye-2 crash was a torn concurrent DynArray append: the byte-clone shares eye-1's sub-object
+    // pointers, so both builds mutate the SAME per-view collection. Give eye-2 its own copies of these
+    // sub-objects so each build appends into a private collection. Page-safe, ~0x400 bytes each.
+    int subCloned = 0;
+    for (uintptr_t subOff : { (uintptr_t)0x40, (uintptr_t)0x60 }) {
+        uintptr_t subPtr = 0;
+        if (!ReadPtrSafe(reinterpret_cast<uintptr_t>(clone) + subOff, &subPtr) || !subPtr) continue;
+        void* subClone = HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, 0x400);
+        if (!subClone) continue;
+        size_t subGood = 0;
+        for (size_t o = 0; o < 0x400; o += 0x100) {
+            if (SafeCopyBytes(reinterpret_cast<uint8_t*>(subClone) + o,
+                              reinterpret_cast<const uint8_t*>(subPtr) + o, 0x100)) subGood = o + 0x100;
+        }
+        if (subGood < 0x100) { HeapFree(GetProcessHeap(), 0, subClone); continue; }
+        // Repoint the clone's sub-pointer to our private copy.
+        uintptr_t subCloneAddr = reinterpret_cast<uintptr_t>(subClone);
+        SafeCopyBytes(reinterpret_cast<uint8_t*>(reinterpret_cast<uintptr_t>(clone) + subOff),
+                      reinterpret_cast<const uint8_t*>(&subCloneAddr), 8);
+        subCloned++;
+    }
+    if (g_eye2CloneCount == 0) {
+        Log("[EYE2-CLONE] sub-objects deep-cloned: %d/2 (+0x40,+0x60)\n", subCloned);
+    }
+    uintptr_t cloneSlot = reinterpret_cast<uintptr_t>(clone);
+    InterlockedIncrement(&g_eye2CloneCount);
+    FgbSubmitFn fn = reinterpret_cast<FgbSubmitFn>(g_gameModuleBase + 0x293568);
+    return fn(a1, a2, a3, a4, &cloneSlot);
+}
+
+// CALL-SITE hook: instead of patching the unwind-fatal submitter prologue, patch the `call sub_140293568`
+// instruction inside its caller sub_140293AF4 (at rva 0x293BCE). Patching a mid-body CALL leaves every
+// function's prologue + .pdata intact (no base-5 unwind crash) and runs the submitter UNPATCHED. The
+// trampoline captures the 5 args (set up immediately before the call: a5=rax stored at [rsp+0x20], a3/a4
+// = lea locals, a1/a2 in rcx/rdx), always issues eye-1, and when F12 is armed issues an identical eye-2
+// (a 2nd genuine submit => fresh job+ctx => 2nd FG-build). All non-volatiles + eye-1's rax preserved.
+bool InstallFGBCallSiteHook() {
+    if (!g_gameModuleBase) { Log("FGB call-site hook: game base unknown\n"); return false; }
+    uint8_t* site = reinterpret_cast<uint8_t*>(g_gameModuleBase + 0x293BCE);
+    static const uint8_t kExpectCall[5] = { 0xE8, 0x95, 0xF9, 0xFF, 0xFF }; // call sub_140293568
+    if (!IsReadableAddressRange(reinterpret_cast<uintptr_t>(site), sizeof(kExpectCall)) ||
+        memcmp(site, kExpectCall, sizeof(kExpectCall)) != 0) {
+        Log("FGB call-site hook: call-bytes mismatch at %p (rva=0x293BCE); aborting\n", site);
+        return false;
+    }
+    const uintptr_t submitter = g_gameModuleBase + 0x293568;
+    const uintptr_t jmpBack   = g_gameModuleBase + 0x293BD3;   // site + 5
+    void* tramp = AllocateTrampoline(site, 256);
+    if (!tramp) return false;
+    uint8_t* code = static_cast<uint8_t*>(tramp);
+    int pos = 0;
+    auto emit = [&](std::initializer_list<uint8_t> b){ for (uint8_t x : b) code[pos++] = x; };
+
+    emit({0x4C,0x8B,0x54,0x24,0x20});                 // mov r10,[rsp+0x20]   (a5)
+    // One-shot-ish capture of the live view-handle (*a5) for present-thread layout dump (eye-2 prereq).
+    emit({0x49,0x8B,0x02});                           // mov rax,[r10]   (*a5 = view handle)
+    emit({0x48,0xA3});                                // mov [abs64], rax  (g_capturedViewHandle)
+    *reinterpret_cast<uint64_t*>(code + pos) = reinterpret_cast<uint64_t>(&g_capturedViewHandle); pos += 8;
+    emit({0x53,0x56,0x57});                           // push rbx,rsi,rdi
+    emit({0x41,0x54,0x41,0x55,0x41,0x56,0x41,0x57});  // push r12,r13,r14,r15  (rsp -= 0x38)
+    emit({0x48,0x8B,0xD9});                           // mov rbx,rcx  (a1)
+    emit({0x48,0x8B,0xF2});                           // mov rsi,rdx  (a2)
+    emit({0x49,0x8B,0xF8});                           // mov rdi,r8   (a3)
+    emit({0x4D,0x8B,0xE1});                           // mov r12,r9   (a4)
+    emit({0x4D,0x8B,0xEA});                           // mov r13,r10  (a5)
+    // --- eye-1 (always) ---
+    emit({0x48,0x83,0xEC,0x38});                      // sub rsp,0x38  (align + shadow + a5 slot)
+    emit({0x48,0x8B,0xCB});                           // mov rcx,rbx
+    emit({0x48,0x8B,0xD6});                           // mov rdx,rsi
+    emit({0x4C,0x8B,0xC7});                           // mov r8,rdi
+    emit({0x4D,0x8B,0xCC});                           // mov r9,r12
+    emit({0x4C,0x89,0x6C,0x24,0x20});                 // mov [rsp+0x20],r13  (a5)
+    WriteMovRaxImm64(code, pos, submitter);           // mov rax, sub_140293568
+    emit({0xFF,0xD0});                                // call rax
+    emit({0x48,0x83,0xC4,0x38});                      // add rsp,0x38
+    emit({0x49,0x89,0xC7});                           // mov r15,rax   (save eye-1 result)
+    // --- armed? ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_fc8Reinvoke)); // mov rax,&flag
+    emit({0x83,0x38,0x00});                           // cmp dword [rax],0
+    emit({0x74,0x32});                                // je .done  (skip 0x32-byte armed block)
+    // --- eye-2 (armed) ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_fc8ReinvokeCount)); // mov rax,&count
+    emit({0xF0,0xFF,0x00});                           // lock inc dword [rax]
+    emit({0x48,0x83,0xEC,0x38});                      // sub rsp,0x38
+    emit({0x48,0x8B,0xCB});                           // mov rcx,rbx
+    emit({0x48,0x8B,0xD6});                           // mov rdx,rsi
+    emit({0x4C,0x8B,0xC7});                           // mov r8,rdi
+    emit({0x4D,0x8B,0xCC});                           // mov r9,r12
+    emit({0x4C,0x89,0x6C,0x24,0x20});                 // mov [rsp+0x20],r13  (a5 = &handleptr)
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&Eye2CloneSubmit)); // eye-2 via shallow-clone handle
+    emit({0xFF,0xD0});                                // call rax
+    emit({0x48,0x83,0xC4,0x38});                      // add rsp,0x38
+    // .done:
+    emit({0x4C,0x89,0xF8});                           // mov rax,r15   (restore eye-1 result)
+    emit({0x41,0x5F,0x41,0x5E,0x41,0x5D,0x41,0x5C});  // pop r15,r14,r13,r12
+    emit({0x5F,0x5E,0x5B});                           // pop rdi,rsi,rbx
+    emit({0xFF,0x25});                                // jmp qword ptr [rip+0]
+    *reinterpret_cast<int32_t*>(code + pos) = 0; pos += 4;
+    *reinterpret_cast<uint64_t*>(code + pos) = static_cast<uint64_t>(jmpBack); pos += 8;
+
+    uint8_t patch[5];
+    patch[0] = 0xE9;
+    *reinterpret_cast<int32_t*>(patch + 1) = static_cast<int32_t>(code - (site + 5));
+    if (!PatchCodeSafely(site, patch, 5)) {
+        Log("FGB call-site hook: safe-patch failed; aborting\n");
+        return false;
+    }
+    Log("FGB call-site hook installed: patched call at %p (rva=0x293BCE) -> tramp %p (%d bytes)\n",
+        site, tramp, pos);
+    return true;
+}
