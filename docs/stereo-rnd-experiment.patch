+// [option-C enroll search] Reverse-link RTT queue packet p1 targets back to their wrapper objects.
+// From static disasm: RTT path `0x140CAF7D4` calls through `[obj+0x98]` (expected wrapper fn
+// `0x140CAF834`) and queue packets carry `p1 = *(obj+0x10)`. So: collect live RTT packet `p1`
+// values from texMgr queues, scan committed RW heap for qword matches, treat hit-0x10 as candidate
+// object base, and flag candidates whose `candidate+0x98 == exeBase+0xCAF834`.
+static void FindRttWrapperObjectsWorker() {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    {
+        std::ofstream start(VRDiagPath("rtt_wrapper_scan.txt"), std::ios::out | std::ios::trunc);
+        if (start.is_open()) {
+            start << "START exeBase=0x" << std::hex << exeBase << std::dec << "\n";
+        }
+    }
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+    auto rd64 = [&](uintptr_t a, uintptr_t* v) -> bool {
+        if (!IsReadableRange(a, 8)) return false;
+        return SehReadU64(a, v);
+    };
+    auto rd32 = [&](uintptr_t a, uint32_t* v) -> bool {
+        if (!IsReadableRange(a, 4)) return false;
+        return SehReadU32(a, v);
+    };
+    auto rd16 = [&](uintptr_t a, uint16_t* v) -> bool {
+        if (!IsReadableRange(a, 2)) return false;
+        return SehReadU16(a, v);
+    };
+
+    std::ostringstream sb;
+    sb << "exe base=0x" << std::hex << exeBase << std::dec << "\n";
+    auto persist = [&]() {
+        std::ofstream out(VRDiagPath("rtt_wrapper_scan.txt"), std::ios::out | std::ios::trunc);
+        if (out.is_open()) { out << sb.str(); out.flush(); }
+    };
+    uintptr_t renderer = 0, texMgr = 0;
+    if (!rd64(exeBase + 0x3427C00, &renderer) || !renderer) {
+        std::ofstream out(VRDiagPath("rtt_wrapper_scan.txt")); out << sb.str() << "FAIL renderer null\n"; return;
+    }
+    if (!rd64(renderer + 0x70, &texMgr) || !texMgr) {
+        std::ofstream out(VRDiagPath("rtt_wrapper_scan.txt")); out << sb.str() << "FAIL texMgr null\n"; return;
+    }
+
+    const uintptr_t kRttCat = exeBase + 0x2B89280;
+    const uintptr_t kWrapperFn = exeBase + 0x0CAF834;
+    std::vector<uintptr_t> targets;
+    auto collectTargetsOnce = [&](int sampleIdx) {
+        int added = 0;
+        for (uintptr_t off = 0x20; off <= 0xC38; off += 0x18) {
+            uintptr_t cur = 0;
+            if (!rd64(texMgr + off + 8, &cur) || !cur || !IsReadableRange(cur, 0x4010)) continue;
+            uint32_t cursor = 0;
+            if (!rd32(cur + 0x4000, &cursor) || cursor < 0xE || cursor > 0x4000) continue;
+            for (uint32_t pos = 0xE, cmd = 0; pos + 0x22 <= cursor && pos + 0x22 < 0x4000 && cmd < 32; ++cmd) {
+                uint16_t size = 0;
+                uintptr_t tag = 0, p0 = 0, p1 = 0;
+                if (!rd16(cur + pos, &size) || size < 0x10 || size > 0x800 || pos + size > 0x4000) break;
+                rd64(cur + pos + 0x2, &tag);
+                rd64(cur + pos + 0xA, &p0);
+                rd64(cur + pos + 0x12, &p1);
+                long long tagRva = rvaOf(tag);
+                if ((tagRva == 0x3133338 || tagRva == 0x3133418) && p0 == kRttCat && p1) {
+                    bool seen = false;
+                    for (uintptr_t t : targets) { if (t == p1) { seen = true; break; } }
+                    if (!seen) { targets.push_back(p1); ++added; }
+                }
+                pos += size;
+            }
+        }
+        sb << "sample[" << sampleIdx << "] targetsNow=" << targets.size() << " added=" << added << "\n";
+    };
+    // RTT preview packets are bursty and often appear only when the user rotates the inventory
+    // puppet. Poll for a few seconds and union all observed p1 targets instead of relying on one frame.
+    for (int sample = 0; sample < 24; ++sample) {
+        collectTargetsOnce(sample);
+        persist();
+        if (sample != 23) Sleep(150);
+    }
+    sb << "targets=" << targets.size() << "  wrapperFn=0x" << std::hex << kWrapperFn << std::dec << "\n";
+    persist();
+
+    struct ScanWindow { uintptr_t lo, hi; };
+    std::vector<ScanWindow> windows;
+
+    int hits = 0;
+    for (uintptr_t t : targets) {
+        MEMORY_BASIC_INFORMATION mbi{};
+        if (VirtualQuery(reinterpret_cast<LPCVOID>(t), &mbi, sizeof(mbi)) == 0) {
+            sb << "target=0x" << std::hex << t << std::dec << " VirtualQuery FAILED\n";
+            continue;
+        }
+        DWORD prot = mbi.Protect & 0xFF;
+        uintptr_t base = reinterpret_cast<uintptr_t>(mbi.BaseAddress);
+        uintptr_t end = base + mbi.RegionSize;
+        const uintptr_t kWindow = 0x02000000; // 32 MB around target is enough and much cheaper than whole region
+        uintptr_t scanLo = (t > kWindow) ? (t - kWindow) : base;
+        if (scanLo < base) scanLo = base;
+        uintptr_t scanHi = (t + kWindow < end) ? (t + kWindow) : end;
+        sb << "\ntarget=0x" << std::hex << t << " region=[0x" << base << "..0x" << end << ")"
+           << " window=[0x" << scanLo << "..0x" << scanHi << ") type=0x" << mbi.Type << " prot=0x" << prot << std::dec << "\n";
+        if (mbi.State != MEM_COMMIT || (mbi.Protect & PAGE_GUARD) || prot == PAGE_NOACCESS) continue;
+        if (mbi.RegionSize < 0x100) continue;
+
+        bool merged = false;
+        for (auto& w : windows) {
+            if (!(scanHi < w.lo || scanLo > w.hi)) {
+                if (scanLo < w.lo) w.lo = scanLo;
+                if (scanHi > w.hi) w.hi = scanHi;
+                merged = true;
+                break;
+            }
+        }
+        if (!merged) windows.push_back({scanLo, scanHi});
+    }
+    for (size_t i = 0; i < windows.size(); ++i) {
+        for (size_t j = i + 1; j < windows.size();) {
+            if (!(windows[i].hi < windows[j].lo || windows[i].lo > windows[j].hi)) {
+                if (windows[j].lo < windows[i].lo) windows[i].lo = windows[j].lo;
+                if (windows[j].hi > windows[i].hi) windows[i].hi = windows[j].hi;
+                windows.erase(windows.begin() + j);
+            } else {
+                ++j;
+            }
+        }
+    }
+    sb << "merged windows=" << windows.size() << "\n";
+    for (size_t wi = 0; wi < windows.size(); ++wi) {
+        sb << "  window[" << wi << "] [0x" << std::hex << windows[wi].lo << "..0x" << windows[wi].hi << ")" << std::dec << "\n";
+    }
+    persist();
+
+    for (size_t wi = 0; wi < windows.size(); ++wi) {
+        uintptr_t scanLo = windows[wi].lo;
+        uintptr_t scanHi = windows[wi].hi;
+        sb << "\nscan merged window[" << wi << "] [0x" << std::hex << scanLo << "..0x" << scanHi << ")" << std::dec << "\n";
+        persist();
+        for (uintptr_t p = scanLo; p + 8 <= scanHi; p += 8) {
+            uintptr_t q = 0;
+            if (!SehReadU64(p, &q)) break;
+            bool match = false;
+            uintptr_t t = 0;
+            for (uintptr_t tt : targets) {
+                if (q == tt) { match = true; t = tt; break; }
+            }
+            if (!match) continue;
+            uintptr_t obj = p - 0x10; // static path emits p1 = *(obj+0x10)
+            if (!IsReadableRange(obj, 0xA8)) continue;
+            uintptr_t fp98 = 0;
+            rd64(obj + 0x98, &fp98);
+            bool isWrapper = (fp98 == kWrapperFn);
+            ++hits;
+            sb << "HIT @0x" << std::hex << p << " -> candidate obj=0x" << obj << "  p1=0x" << q
+               << "  fp98=0x" << fp98;
+            if (isWrapper) sb << "  <== WRAPPER MATCH";
+            else {
+                long long fr = rvaOf(fp98);
+                if (fr >= 0) sb << "  (module rva=0x" << fr << ")";
+            }
+            sb << std::dec << "\n";
+            for (uintptr_t off = 0; off <= 0xB0; off += 8) {
+                uintptr_t v = 0;
+                if (!rd64(obj + off, &v)) break;
+                sb << "  +0x" << std::hex << off << ": 0x" << v;
+                long long vr = rvaOf(v);
+                if (vr >= 0) sb << "  (module rva=0x" << vr << ")";
+                else if (IsReadableRange(v, 8)) {
+                    uintptr_t inner = 0;
+                    if (rd64(v, &inner)) {
+                        long long ir = rvaOf(inner);
+                        if (ir >= 0) sb << "  (heap obj vtRva=0x" << ir << ")";
+                    }
+                }
+                sb << std::dec << "\n";
+            }
+
+            // Search a small window backwards for a higher-level wrapper whose +0x10 also equals p1,
+            // but whose +0x98 is an EXECUTABLE module pointer. This is cheap and directly tests the
+            // static hypothesis from 0x140CAF7D4: the true object may be a parent/larger record near
+            // the obvious hit, not the immediate `p-0x10` candidate.
+            sb << "  nearby bases:\n";
+            uintptr_t winLo = (p > 0x200) ? (p - 0x200) : scanLo;
+            if (winLo < scanLo) winLo = scanLo;
+            for (uintptr_t cand = winLo; cand + 0xA0 <= p; cand += 8) {
+                uintptr_t at10 = 0;
+                if (!rd64(cand + 0x10, &at10) || at10 != t) continue;
+                uintptr_t fp = 0;
+                if (!rd64(cand + 0x98, &fp)) continue;
+                MEMORY_BASIC_INFORMATION mbi2{};
+                bool exec = false;
+                long long fr = -1;
+                if (fp >= 0x10000 && fp < 0x7fffffffffffULL && VirtualQuery(reinterpret_cast<LPCVOID>(fp), &mbi2, sizeof(mbi2)) != 0) {
+                    DWORD p2 = mbi2.Protect & 0xFF;
+                    exec = (mbi2.State == MEM_COMMIT) && !(mbi2.Protect & PAGE_GUARD) &&
+                           (p2 == PAGE_EXECUTE || p2 == PAGE_EXECUTE_READ || p2 == PAGE_EXECUTE_READWRITE || p2 == PAGE_EXECUTE_WRITECOPY);
+                }
+                fr = rvaOf(fp);
+                sb << "    cand=0x" << std::hex << cand << "  fp98=0x" << fp;
+                if (fr >= 0) sb << " rva=0x" << fr;
+                if (exec) sb << "  <== EXECUTABLE";
+                sb << std::dec << "\n";
+            }
+            persist();
+        }
+    }
+    sb << "\n==== done: " << hits << " candidate hits ====\n";
+    persist();
+}
