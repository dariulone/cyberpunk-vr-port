+// RTTI entry: launch the heavy registry read on a detached worker thread and return immediately, so
+// the game main thread (where the CET console command runs) never stalls -> no freeze/TDR. The file
+// rendertex_entries.txt appears a moment (<<1s) later. Returns 1 = launched.
+void DumpRenderTexEntries(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    std::thread(&RenderTexEntriesWorker).detach();
+    if (aOut) *aOut = 1;
+}
