+// SEH helpers for the all-cams enable scan (kept as plain static fns so __try is legal here).
+static int SehScanRegionForVt(uintptr_t lo, uintptr_t hi, uintptr_t needle, uintptr_t* outArr, int maxOut) {
+    int n = 0;
+    __try {
+        for (uintptr_t p = lo; p + 8 <= hi; p += 8) {
+            if (*reinterpret_cast<volatile uintptr_t*>(p) == needle) { if (n < maxOut) outArr[n++] = p; else break; }
+        }
+    } __except (EXCEPTION_EXECUTE_HANDLER) {}
+    return n;
+}
+static bool SehEnableRttCam(uintptr_t obj) {
+    __try {
+        *reinterpret_cast<volatile uint32_t*>(obj + 0x290) = 0;   // renderingMode = Shaded
+        *reinterpret_cast<volatile uint8_t*>(obj + 0x8b) = 1;     // isEnabled = true
+        return true;
+    } __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+}
+
+// [option-C native True Stereo] Cheap decisive test: enable EVERY currently-disabled RTT cam in the
+// process (heap scan by vtable exe+0x307BFD0, only those with comp+0x88 == 0x3 == valid+disabled),
+// off-thread so the frame never stalls. If ANY of them then gets a comp+0x1E8 handle (checked via
+// live-RPM), then isEnabled alone is sufficient to drive an RTT render -> huge simplification, no
+// render-attach reverse needed. If none attach, the entity must also be render-active -> proceed to
+// the player-add path. Writes rttcam_enable_all.txt (addresses + before/after) for live-RPM follow-up.
+static void ForceEnableAllRTTCamsWorker() {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    const uintptr_t needle = exeBase + 0x307BFD0;
+    std::ostringstream sb;
+    sb << "START needle=0x" << std::hex << needle << std::dec << "\n";
+
+    int found = 0, enabled = 0;
+    uintptr_t regionHits[64];
+    MEMORY_BASIC_INFORMATION mbi{};
+    uintptr_t addr = 0x10000000000ull;
+    const uintptr_t addrEnd = 0x30000000000ull;
+    while (addr < addrEnd) {
+        if (VirtualQuery(reinterpret_cast<LPCVOID>(addr), &mbi, sizeof(mbi)) == 0) { addr += 0x1000; continue; }
+        uintptr_t base = reinterpret_cast<uintptr_t>(mbi.BaseAddress);
+        uintptr_t next = base + mbi.RegionSize;
+        DWORD prot = mbi.Protect & 0xFF;
+        bool readable = (mbi.State == MEM_COMMIT) && !(mbi.Protect & PAGE_GUARD) && prot != PAGE_NOACCESS &&
+                        (mbi.Type == MEM_PRIVATE || mbi.Type == MEM_MAPPED);
+        if (readable && mbi.RegionSize >= 0x100) {
+            int n = SehScanRegionForVt(base, next, needle, regionHits, 64);
+            for (int i = 0; i < n; ++i) {
+                uintptr_t obj = regionHits[i];
+                uintptr_t flag88 = 0, resref = 0;
+                if (!SehReadU64(obj + 0x88, &flag88)) continue;
+                SehReadU64(obj + 0x1E0, &resref);
+                ++found;
+                if (flag88 == 0x3) {  // valid RTT cam, currently disabled
+                    bool ok = SehEnableRttCam(obj);
+                    uintptr_t after = 0; SehReadU64(obj + 0x88, &after);
+                    sb << "ENABLE obj=0x" << std::hex << obj << " resref=0x" << resref
+                       << " +0x88 0x3->0x" << after << (ok ? "" : " (WRITE FAIL)") << std::dec << "\n";
+                    if (ok) ++enabled;
+                } else {
+                    sb << "skip   obj=0x" << std::hex << obj << " +0x88=0x" << flag88 << " resref=0x" << resref << std::dec << "\n";
+                }
+            }
+        }
+        addr = (next > addr) ? next : addr + 0x1000;
+    }
+    sb << "==== found " << found << " RTT cam(s), enabled " << enabled << " ====\n";
+    std::ofstream out(VRDiagPath("rttcam_enable_all.txt"), std::ios::out | std::ios::trunc);
+    out << sb.str();
+}
+void ForceEnableAllRTTCams(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    std::thread(&ForceEnableAllRTTCamsWorker).detach();
+    if (aOut) *aOut = 1;
+}
