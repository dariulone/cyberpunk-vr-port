+        D3D12_RESOURCE_BARRIER fin[2]{};
+        fin[0].Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION; fin[0].Transition.pResource = f->texture;
+        fin[0].Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
+        fin[0].Transition.StateBefore = D3D12_RESOURCE_STATE_COPY_DEST; fin[0].Transition.StateAfter = D3D12_RESOURCE_STATE_COPY_SOURCE;
+        fin[1].Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION; fin[1].Transition.pResource = m_sbsTempRT[eye];
+        fin[1].Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
+        fin[1].Transition.StateBefore = D3D12_RESOURCE_STATE_COPY_SOURCE; fin[1].Transition.StateAfter = D3D12_RESOURCE_STATE_COMMON;
+        cl->ResourceBarrier(2, fin);
