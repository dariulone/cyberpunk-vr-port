+// Set/clear a hardware write watchpoint (DR0, 8-byte) on `addr` across every thread of this process.
+// Called from the present thread; suspends the others while writing their debug registers.
+static int SetHwWatchAllThreads(uintptr_t addr, bool enable) {
+    DWORD myPid = GetCurrentProcessId();
+    DWORD myTid = GetCurrentThreadId();
+    HANDLE snap = CreateToolhelp32Snapshot(TH32CS_SNAPTHREAD, 0);
+    if (snap == INVALID_HANDLE_VALUE) return -1;
+    THREADENTRY32 te; te.dwSize = sizeof(te);
+    int touched = 0;
+    if (Thread32First(snap, &te)) {
+        do {
+            if (te.dwSize >= FIELD_OFFSET(THREADENTRY32, th32OwnerProcessID) + sizeof(te.th32OwnerProcessID)
+                && te.th32OwnerProcessID == myPid) {
+                HANDLE h = OpenThread(THREAD_GET_CONTEXT | THREAD_SET_CONTEXT | THREAD_SUSPEND_RESUME,
+                                      FALSE, te.th32ThreadID);
+                if (h) {
+                    bool other = (te.th32ThreadID != myTid);
+                    if (other) SuspendThread(h);
+                    CONTEXT c; c.ContextFlags = CONTEXT_DEBUG_REGISTERS;
+                    if (GetThreadContext(h, &c)) {
+                        if (enable) { c.Dr0 = addr; c.Dr6 = 0; c.Dr7 = 0x90001ull; }   // L0 + write + 8-byte
+                        else        { c.Dr0 = 0;    c.Dr6 = 0; c.Dr7 = 0; }
+                        c.ContextFlags = CONTEXT_DEBUG_REGISTERS;
+                        if (SetThreadContext(h, &c)) ++touched;
+                    }
+                    if (other) ResumeThread(h);
+                    CloseHandle(h);
+                }
+            }
+            te.dwSize = sizeof(te);
+        } while (Thread32Next(snap, &te));
+    }
+    CloseHandle(snap);
+    return touched;
