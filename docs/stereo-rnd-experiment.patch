+    std::ofstream out(VRDiagPath("rendertex_state.txt"), std::ios::out | std::ios::trunc);
+    if (g_keepAliveRenderTex.empty()) { out << "no render-tex created yet\n"; if (aOut) *aOut = -1; return; }
+    uintptr_t obj = reinterpret_cast<uintptr_t>(g_keepAliveRenderTex.back());
