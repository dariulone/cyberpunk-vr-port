+// [option-C native True Stereo] DECISIVE LEVER TEST: call the engine's OWN RTT-camera view-create
+// activation wrapper (sub_140AC316C = producer vtable exe+0x2B03A70 offset 0x40 / slot 8) on found RTT-camera
+// components, and log whether a render-texture handle (comp+0x1E8 / +0x200 / +0x218 / +0x230) appears
+// as a result. The wrapper runs the one-time-init (sub_140AC2BA4) THEN the view-create (sub_1404FBAFC),
+// whose gate (sub_140665054) passes only if a handle already exists.
+// RESOLVED (2026-06-09, IDA byte-decode): the one-time-init sub_140AC2BA4 does NOT allocate the handle
+// -- it only READS comp+0x1E8 and comp+0x258/0x25C (resolution); no write to any gate slot
+// (+0x1E8/+0x200/+0x218/+0x230). sub_1404FBAFC and sub_1404A04AC likewise only consume the handle.
+// => mode 2 (idle cam) is PROVEN futile: gate no-ops, init won't fill the handle. The handle is created
+//    strictly upstream by the render-attach lifecycle. mode 1 (active cam) would only re-drive an
+//    already-rendering view (same handle), not a 2nd eye. So this lever is exhausted for handle alloc.
+// Heap-scan finds cams by component vtable exe+0x307BFD0 (same needle as ForceEnableAllRTTCams). The
+// wrapper takes the +0x120 sub-object (rcx); it derives comp = rcx-0x120 internally. We verify the
+// sub-object's vtable == prodVt before calling (safety). mode: 0=all, 1=already-active only (safe
+// lever-proof), 2=idle only (handle-alloc test). Runs synchronously on the script (main) thread so the
+// engine call lands on the right thread; the heap scan briefly hitches the frame (one-shot diagnostic).
+// Returns: >0 = #cams where a handle was newly allocated, 0 = called but no new handle, -1 = none found.
+// NOTE ON THREADING: an earlier version called the wrapper synchronously from the CET/script thread
+// and DEADLOCKED the game (view registration via renderer[0x450] enqueues a render command and waits;
+// the render thread was itself waiting on the blocked main thread -> deadlock). Also the 2TB heap scan
+// on the main thread froze the frame. So this native is now READ-ONLY + off-thread: it ONLY locates
+// candidate RTT-cam components and logs them (cp, flag88, prodVt match, handles). The actual wrapper
+// call must be issued from an engine-thread hook in a safe frame phase -- wired separately, not here.
+typedef void(__fastcall* RttViewWrapFn)(uintptr_t);
+static void DriveRTTViewCreateWorker(int mode) {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    const uintptr_t compVt = exeBase + 0x307BFD0;   // entRenderToTextureCameraComponent vtable (needle)
+    const uintptr_t prodVt = exeBase + 0x2B03A70;   // producer sub-object vtable (CORRECTED: was +0x2B03A80; live-scan+IDA-byte confirmed real base is +0x2B03A70; wrapper sub_140AC316C at offset 0x40 = slot 8, NOT slot 6)
+
+    std::ostringstream sb;
+    sb << "READ-ONLY scan (no wrapper call -- see threading note). exeBase=0x" << std::hex << exeBase
+       << " compVt=0x" << compVt << " prodVt=0x" << prodVt << " wrapFn=0x" << (exeBase + 0xAC316C)
+       << std::dec << "  mode=" << mode << " (0=all,1=active-only,2=idle-only)\n";
+
+    int found = 0, listed = 0, prodMatch = 0;
+    uintptr_t hits[64];
+    MEMORY_BASIC_INFORMATION mbi{};
+    uintptr_t addr = 0x10000000000ull;
+    const uintptr_t addrEnd = 0x30000000000ull;
+    while (addr < addrEnd) {
+        if (VirtualQuery(reinterpret_cast<LPCVOID>(addr), &mbi, sizeof(mbi)) == 0) { addr += 0x1000; continue; }
+        uintptr_t base = reinterpret_cast<uintptr_t>(mbi.BaseAddress);
+        uintptr_t next = base + mbi.RegionSize;
+        DWORD prot = mbi.Protect & 0xFF;
+        bool readable = (mbi.State == MEM_COMMIT) && !(mbi.Protect & PAGE_GUARD) && prot != PAGE_NOACCESS &&
+                        (mbi.Type == MEM_PRIVATE || mbi.Type == MEM_MAPPED);
+        if (readable && mbi.RegionSize >= 0x100) {
+            int n = SehScanRegionForVt(base, next, compVt, hits, 64);
+            for (int i = 0; i < n; ++i) {
+                uintptr_t cp = hits[i];
+                uint64_t flag88 = 0;
+                if (!SehReadU64(cp + 0x88, &flag88)) continue;
+                bool isActive = (flag88 & 0x01000000ull) != 0;   // +0x88 == 0x01000003 active vs 0x3 idle
+                ++found;
+                if (mode == 1 && !isActive) continue;
+                if (mode == 2 &&  isActive) continue;
+
+                uintptr_t subobj = cp + 0x120;
+                uintptr_t subVt = 0;
+                if (!SehReadU64(subobj, &subVt)) { sb << "skip cp=0x" << std::hex << cp << " (subobj unreadable)\n" << std::dec; continue; }
+                uint64_t hb[4] = {0,0,0,0};
+                SehReadU64(cp + 0x1E8, &hb[0]); SehReadU64(cp + 0x200, &hb[1]);
+                SehReadU64(cp + 0x218, &hb[2]); SehReadU64(cp + 0x230, &hb[3]);
+                bool match = (subVt == prodVt);
+                if (match) ++prodMatch;
+                ++listed;
+                sb << (isActive ? "ACTIVE" : "idle  ") << " cp=0x" << std::hex << cp
+                   << " subobj=0x" << subobj << " flag88=0x" << flag88 << " subVt=0x" << subVt
+                   << (match ? " (prodVt MATCH -> callable target)" : " (prodVt MISMATCH)")
+                   << " h[1E8/200/218/230]=0x" << hb[0] << "/0x" << hb[1] << "/0x" << hb[2] << "/0x" << hb[3]
+                   << std::dec << "\n";
+            }
+        }
+        addr = (next > addr) ? next : addr + 0x1000;
+    }
+    sb << "==== found " << found << " RTT cam(s); listed " << listed
+       << " (mode-filtered); prodVt-callable " << prodMatch << " ====\n";
+    std::ofstream out(VRDiagPath("rttcam_viewcreate.txt"), std::ios::out | std::ios::trunc);
+    out << sb.str();
+}
+void DriveRTTViewCreate(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t mode = 0;
+    RED4ext::GetParameter(aFrame, &mode);
+    aFrame->code++;
+    std::thread(&DriveRTTViewCreateWorker, (int)mode).detach();   // off-thread: never freezes the frame
+    if (aOut) *aOut = 1;
+}
