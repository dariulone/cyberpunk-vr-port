+// [Skip Tick] CONFIRMED mechanism (user CET test 2026-06-09): gameTimeSystem::SetTimeDilation(reason,~0)
+// freezes the gameplay sim (NPCs/V/vehicles/physics/animations) — the dominant ghosting source. This is
+// the plugin-side call (building block for the per-frame Skip Tick). script_ref params built as
+// ScriptRef<T> (NativeTypes.hpp: innerType@0x10, ref@0x18). Returns 1/0, <0 on lookup failure.
+static int32_t VRCallTimeDilation(bool aSet, float aValue) {
+    auto* sys = GetGameSystem<RED4ext::IScriptable>("gameTimeSystem");
+    if (!sys) return -1;
+    auto* cls = sys->GetType();
+    if (!cls) return -2;
+    auto* rtti = RED4ext::CRTTISystem::Get();
+    if (!rtti) return -5;
+    auto* cnameType = rtti->GetType("CName");
+    auto* floatType = rtti->GetType("Float");
+
+    RED4ext::CName reason("vrtest");
+    RED4ext::CName emptyName("None");
+    float dilation = aValue;
+    float duration = 0.0f;   // instant, no ease
+
+    if (aSet) {
+        auto* fn = cls->GetFunction("SetTimeDilation");
+        if (!fn) return -3;
+        RED4ext::ScriptRef<RED4ext::CName> reasonRef{}; reasonRef.innerType = cnameType; reasonRef.ref = &reason;
+        RED4ext::ScriptRef<float> dilRef{};            dilRef.innerType = floatType;    dilRef.ref = &dilation;
+        RED4ext::ScriptRef<float> durRef{};            durRef.innerType = floatType;    durRef.ref = &duration;
+        RED4ext::ScriptRef<RED4ext::CName> eInRef{};   eInRef.innerType = cnameType;    eInRef.ref = &emptyName;
+        RED4ext::ScriptRef<RED4ext::CName> eOutRef{};  eOutRef.innerType = cnameType;   eOutRef.ref = &emptyName;
+        RED4ext::StackArgs_t args;
+        args.emplace_back(fn->params.Size() > 0 ? fn->params[0]->type : nullptr, &reasonRef);
+        args.emplace_back(fn->params.Size() > 1 ? fn->params[1]->type : nullptr, &dilRef);
+        args.emplace_back(fn->params.Size() > 2 ? fn->params[2]->type : nullptr, &durRef);
+        args.emplace_back(fn->params.Size() > 3 ? fn->params[3]->type : nullptr, &eInRef);
+        args.emplace_back(fn->params.Size() > 4 ? fn->params[4]->type : nullptr, &eOutRef);
+        RED4ext::ExecuteFunction(reinterpret_cast<void*>(sys), fn, nullptr, args);
+        return 1;
+    } else {
+        auto* fn = cls->GetFunction("UnsetTimeDilation");
+        if (!fn) return -3;
+        RED4ext::ScriptRef<RED4ext::CName> reasonRef{}; reasonRef.innerType = cnameType; reasonRef.ref = &reason;
+        RED4ext::ScriptRef<RED4ext::CName> eOutRef{};   eOutRef.innerType = cnameType;   eOutRef.ref = &emptyName;
+        RED4ext::StackArgs_t args;
+        args.emplace_back(fn->params.Size() > 0 ? fn->params[0]->type : nullptr, &reasonRef);
+        args.emplace_back(fn->params.Size() > 1 ? fn->params[1]->type : nullptr, &eOutRef);
+        RED4ext::ExecuteFunction(reinterpret_cast<void*>(sys), fn, nullptr, args);
+        return 0;
+    }
+}
+void VRFreezeDil(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    int32_t r = VRCallTimeDilation(true, 0.0001f);
+    if (aOut) *aOut = r;
+}
+void VRUnfreezeDil(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    int32_t r = VRCallTimeDilation(false, 1.0f);
+    if (aOut) *aOut = r;
+}
