+// the render/streaming thread mutating this array): (1) every pointer is VirtualQuery-validated
+// (committed, non-guard, readable) BEFORE any dereference, not just SEH; (2) the output stream is
+// flushed after every line so a crash never loses captured data. Pure reads. Run with inventory
+// puppet-preview OPEN. Writes rendertex_entries.txt. Returns count of live records dumped.
+// Worker body: runs on a DETACHED thread, NOT the game main thread. CET console commands execute
+// in-frame on the main thread; stalling it while reading the live, render-thread-mutated texMgr
+// registry caused the freeze/TDR (the read completes, but the frame stall trips the GPU watchdog).
+// Off-thread, the main thread returns instantly and keeps presenting frames -> no freeze. Reads stay
+// read-only + VirtualQuery/SEH-guarded against concurrent teardown of registry entries.
+static void RenderTexEntriesWorker() {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long rva = (long long)(p - exeBase);
+        return (rva >= 0 && rva < 0x10000000) ? rva : -1;
+    };
+    // VirtualQuery-gated readability: region committed, readable, not guard/noaccess, range fits.
+    auto isReadable = [](uintptr_t a, size_t n) -> bool {
+        if (a < 0x10000 || a > 0x7fffffffffffULL) return false;
+        MEMORY_BASIC_INFORMATION mbi{};
+        if (VirtualQuery(reinterpret_cast<LPCVOID>(a), &mbi, sizeof(mbi)) == 0) return false;
+        if (mbi.State != MEM_COMMIT) return false;
+        DWORD prot = mbi.Protect;
+        if (prot & PAGE_GUARD) return false;
+        DWORD base = prot & 0xFF;
+        if (base == PAGE_NOACCESS) return false;
+        uintptr_t regEnd = reinterpret_cast<uintptr_t>(mbi.BaseAddress) + mbi.RegionSize;
+        return (a + n) <= regEnd;
+    };
+    auto rd = [&](uintptr_t a, uintptr_t* v) -> bool {
+        if (!isReadable(a, 8)) return false;
+        __try { *v = *reinterpret_cast<uintptr_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    // Buffer everything in memory and write ONCE at the end. (Per-line flush on the game's main
+    // thread froze the game: thousands of disk flushes stalled the frame -> hang/TDR. The reads
+    // themselves complete fine; only the I/O cost mattered.)
+    std::ostringstream sb;
+    sb << "exe base=0x" << std::hex << exeBase << std::dec << "\n";
+
+    uintptr_t renderer = 0, texMgr = 0;
+    if (!rd(exeBase + 0x3427C00, &renderer) || renderer == 0) {
+        std::ofstream o(VRDiagPath("rendertex_entries.txt")); o << sb.str() << "FAIL renderer null\n";
+        return;
+    }
+    if (!rd(renderer + 0x70, &texMgr) || texMgr == 0) {
+        std::ofstream o(VRDiagPath("rendertex_entries.txt")); o << sb.str() << "FAIL texMgr null\n";
+        return;
+    }
+    sb << "renderer=0x" << std::hex << renderer << " texMgr=0x" << texMgr << std::dec << "\n";
+
+    // qword dump helper (annotates module rva / heap-obj vtRva / plausible WxH split)
+    auto dumpQ = [&](uintptr_t base, uintptr_t lo, uintptr_t hi, const char* indent) {
+        for (uintptr_t off = lo; off <= hi; off += 8) {
+            uintptr_t q = 0;
+            if (!rd(base + off, &q)) { sb << indent << "+0x" << std::hex << off << ": <unreadable>\n" << std::dec; break; }
+            sb << indent << "+0x" << std::hex << off << ": 0x" << q;
+            long long mr = rvaOf(q);
+            if (mr >= 0) sb << "  (module rva=0x" << mr << ")";
+            else if (isReadable(q, 8)) {
+                uintptr_t inner = 0;
+                if (rd(q, &inner)) { long long ir = rvaOf(inner); if (ir >= 0) sb << "  (heap obj vtRva=0x" << ir << ")"; }
+            }
+            uint32_t a = (uint32_t)(q & 0xffffffff), b = (uint32_t)(q >> 32);
+            if (a >= 16 && a <= 16384 && b >= 16 && b <= 16384) sb << "  <WxH? " << std::dec << a << "x" << b << ">";
+            sb << std::dec << "\n";
+        }
+    };
+    auto follow = [&](uintptr_t ptr, const char* tag) {
+        if (ptr == 0) { sb << "    " << tag << " null\n"; return; }
+        if (!isReadable(ptr, 0x10)) { sb << "    " << tag << " 0x" << std::hex << ptr << std::dec << " <unreadable>\n"; return; }
+        uintptr_t vt = 0; long long vr = -1; if (rd(ptr, &vt)) vr = rvaOf(vt);
+        sb << "    " << tag << " 0x" << std::hex << ptr << " vtRva=0x" << (vr >= 0 ? vr : 0) << std::dec
+           << (vr >= 0 ? "" : " (non-module)") << "\n";
+        dumpQ(ptr, 0, 0x40, "        ");
+    };
+
+    // Walk slots from texMgr+0x20, stride 0x18. The prior {obj==dup} invariant was WRONG (the two
+    // slot pointers are not always equal). Real render-texture records are identified by a stable
+    // TYPE TAG: obj+0x10 points to module rva 0x3133338 (same across all records last run; RVAs are
+    // session-stable). Terminate after a run of non-tagged slots (= left the array). The first few
+    // slots are dumped unconditionally for structure visibility even if the tag doesn't match.
+    const uintptr_t kStart = 0x20, kStride = 0x18, kMaxSlots = 300, kTypeTagRva = 0x3133338, kMaxMiss = 16;
+    int32_t dumped = 0, miss = 0;
+    for (uintptr_t i = 0; i < kMaxSlots; ++i) {
+        uintptr_t slot = texMgr + kStart + i * kStride;
+        uintptr_t obj = 0, dup = 0, tail = 0;
+        rd(slot, &obj);
+        rd(slot + 8, &dup);
+        rd(slot + 16, &tail);
+
+        // type-tag test: is obj a render-texture record?
+        bool isTex = false;
+        if (isReadable(obj, 0x18)) {
+            uintptr_t tag = 0;
+            if (rd(obj + 0x10, &tag) && rvaOf(tag) == (long long)kTypeTagRva) isTex = true;
+        }
+
+        if (!isTex) {
+            if (i < 6) { // structure-visibility dump for the first slots even when untagged
+                sb << "\n[" << i << "] NON-TEX slot+0x" << std::hex << (kStart + i * kStride)
+                   << " obj=0x" << obj << " dup=0x" << dup << " tail=0x" << tail << std::dec << "\n";
+                if (isReadable(obj, 0x18)) dumpQ(obj, 0, 0x30, "  ");
+            }
+            if (++miss >= (int)kMaxMiss) { sb << "\n-- end: " << miss << " consecutive non-tex slots at i=" << i << " --\n"; break; }
+            continue;
+        }
+        miss = 0;
+
+        uintptr_t vt = 0; long long vtr = -1; if (rd(obj, &vt)) vtr = rvaOf(vt);
+        sb << "\n[" << i << "] obj=0x" << std::hex << obj << " dup=0x" << dup << " tail=0x" << tail
+           << " vtRva=0x" << (vtr >= 0 ? vtr : 0) << std::dec << (vtr >= 0 ? "" : " (non-module)") << "\n";
+        dumpQ(obj, 0, 0x50, "  ");
+
+        // follow the two interesting sub-objects to expose resolution + generator class
+        uintptr_t sub20 = 0, sub40 = 0;
+        rd(obj + 0x20, &sub20);
+        rd(obj + 0x40, &sub40);
+        follow(sub20, "sub@+0x20 (resource?)");
+        follow(sub40, "sub@+0x40 (generator?)");
+        ++dumped;
+    }
+
+    sb << "\n==== done: " << dumped << " live records ====\n";
+    {
+        std::ofstream out(VRDiagPath("rendertex_entries.txt"), std::ios::out | std::ios::trunc);
+        if (out.is_open()) out << sb.str();
+    }
+}
