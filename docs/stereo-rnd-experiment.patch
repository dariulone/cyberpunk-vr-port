+        rb.Type = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION; rb.Transition.pResource = m_sbsTempRT[eye];
+        rb.Transition.Subresource = D3D12_RESOURCE_BARRIER_ALL_SUBRESOURCES;
+        rb.Transition.StateBefore = D3D12_RESOURCE_STATE_COMMON; rb.Transition.StateAfter = D3D12_RESOURCE_STATE_RENDER_TARGET;
