+        << "  refcount@+8=" << *reinterpret_cast<uint32_t*>(obj + 0x8) << "\n";
+    for (uintptr_t off = 0; off <= 0x100; off += 8) {
+        uintptr_t q = 0; if (!readPtr(obj + off, &q)) break;
