+// Compile HLSL -> bytecode blob. Returns nullptr + logs errors on failure.
+Microsoft::WRL::ComPtr<IDxcBlob> StereoCompile(const std::string& src, const wchar_t* target, const char* tag) {
+    Microsoft::WRL::ComPtr<IDxcBlob> obj;
+    if (!StereoDxcInit()) return obj;
+    DxcBuffer buf{ src.c_str(), src.size(), DXC_CP_UTF8 };
+    LPCWSTR args[] = { L"-T", target, L"-E", L"main", L"-O3" };
+    Microsoft::WRL::ComPtr<IDxcResult> res;
+    const HRESULT hr = g_dxcComp->Compile(&buf, args, _countof(args), nullptr, IID_PPV_ARGS(&res));
+    HRESULT status = E_FAIL;
+    if (res) res->GetStatus(&status);
+    if (SUCCEEDED(hr) && SUCCEEDED(status)) {
+        if (res) res->GetOutput(DXC_OUT_OBJECT, IID_PPV_ARGS(&obj), nullptr);
+    } else {
+        Microsoft::WRL::ComPtr<IDxcBlobUtf8> errs;
+        if (res) res->GetOutput(DXC_OUT_ERRORS, IID_PPV_ARGS(&errs), nullptr);
+        Log("[STEREO-SHADER] %s compile FAILED hr=0x%08X status=0x%08X errs=%s\n",
+            tag, static_cast<unsigned>(hr), static_cast<unsigned>(status),
+            (errs && errs->GetStringPointer()) ? errs->GetStringPointer() : "<none>");
+    }
+    return obj;
+}
