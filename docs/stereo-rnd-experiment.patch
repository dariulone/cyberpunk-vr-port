+    // returns to us. Used by M3 to schedule the main view a second time without re-entering the hook.
+    uint8_t* origThunk = code + pos;
+    code[pos++] = 0x4C; code[pos++] = 0x8B; code[pos++] = 0xDC;                          // mov r11,rsp
+    code[pos++] = 0x49; code[pos++] = 0x89; code[pos++] = 0x5B; code[pos++] = 0x08;      // mov [r11+8],rbx
+    code[pos++] = 0x49; code[pos++] = 0x89; code[pos++] = 0x6B; code[pos++] = 0x10;      // mov [r11+10],rbp
+    code[pos++] = 0x49; code[pos++] = 0x89; code[pos++] = 0x73; code[pos++] = 0x18;      // mov [r11+18],rsi
+    code[pos++] = 0xFF; code[pos++] = 0x25;                                              // jmp qword ptr [rip+0]
