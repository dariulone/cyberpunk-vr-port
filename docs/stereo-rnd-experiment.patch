+    if (!m_sbsSrvHeap) {
+        D3D12_DESCRIPTOR_HEAP_DESC d{}; d.Type = D3D12_DESCRIPTOR_HEAP_TYPE_CBV_SRV_UAV; d.NumDescriptors = 1;
+        d.Flags = D3D12_DESCRIPTOR_HEAP_FLAG_SHADER_VISIBLE;
