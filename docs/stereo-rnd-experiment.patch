+    code[pos++] = 0x50;                       // push rax
+    code[pos++] = 0x51;                       // push rcx
+    code[pos++] = 0x52;                       // push rdx
+    code[pos++] = 0x41; code[pos++] = 0x50;   // push r8
+    code[pos++] = 0x41; code[pos++] = 0x51;   // push r9
+    code[pos++] = 0x41; code[pos++] = 0x52;   // push r10
