+// Acquire a recycled-or-new compensation allocator+list (open for recording).
+// g_m0CompMutex must be held. Returns pool index or -1.
+int M0AcquireCompSlot() {
+    const uint64_t completed = g_m0CompFence->GetCompletedValue();
+    for (size_t i = 0; i < g_m0CompPool.size(); ++i) {
+        if (g_m0CompPool[i].fenceValue <= completed) {
+            if (FAILED(g_m0CompPool[i].alloc->Reset())) return -1;
+            if (FAILED(g_m0CompPool[i].list->Reset(g_m0CompPool[i].alloc.Get(), nullptr))) return -1;
+            return static_cast<int>(i);
+        }
+    }
+    if (g_m0CompPool.size() >= 64) return -1;
+    M0CompSlot slot;
+    if (FAILED(g_m0CompDevice->CreateCommandAllocator(D3D12_COMMAND_LIST_TYPE_DIRECT, IID_PPV_ARGS(&slot.alloc)))) return -1;
+    if (FAILED(g_m0CompDevice->CreateCommandList(0, D3D12_COMMAND_LIST_TYPE_DIRECT, slot.alloc.Get(), nullptr, IID_PPV_ARGS(&slot.list)))) return -1;
+    g_m0CompPool.push_back(std::move(slot));
+    return static_cast<int>(g_m0CompPool.size() - 1);
+}
