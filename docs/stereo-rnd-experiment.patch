+        for (uintptr_t off = 0x80; off <= 0x2A0; off += 16) {
+            uintptr_t q0 = 0, q1 = 0;
+            bool ok0 = readPtrSafe(comp + off, &q0);
+            bool ok1 = readPtrSafe(comp + off + 8, &q1);
+            if (!ok0) break;
+            out << "  +0x" << std::hex << off << ": " << q0;
+            if (ok1) out << " " << q1;
+            out << " | " << (uint32_t)(q0 & 0xffffffff) << " " << (uint32_t)(q0 >> 32);
+            if (ok1) out << " " << (uint32_t)(q1 & 0xffffffff) << " " << (uint32_t)(q1 >> 32);
+            out << std::dec << "\n";
+        }
+    }
+
+    out.close();
+    if (aOut) *aOut = found;
+}
