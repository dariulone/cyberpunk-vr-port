+// [option-C native True Stereo] ATTACH-TRIGGER EXPERIMENT.
+// Decisive finding: the live attached-vs-detached diff of the WORKING preview camera differs in
+// exactly ONE byte -- comp+0x88 = 0x01000003 (attached) vs 0x3 (detached) -- and RTTI says byte
+// 0x8b is the `isEnabled` Bool. So "attached" == isEnabled=1. The inventory preview driver simply
+// sets isEnabled=1, and the engine then creates comp+0x1E8 (GPU handle) + renders the camera.
+// Hypothesis B: our script RTT cam never renders because isEnabled stays 0. This test sets
+//   isEnabled(@0x8b)=1, renderingMode(@0x290)=Shaded(0), resolution(@0x258/@0x25c)=w/h
+// on the player's RTT cam(s), logs comp+0x88/+0x1E8 before/after, and returns the count.
+// VERIFY (no rebuild): after running, poll comp+0x1E8 via live-RPM -- if a handle appears within a
+// few frames, the engine attached/GPU-backed our camera => native true-stereo path is unblocked.
+// Returns: count of cams enabled, negative on failure stage.
+void ForceEnableRTTCamera(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    int32_t w = 0, h = 0;
+    RED4ext::GetParameter(aFrame, &w);
+    RED4ext::GetParameter(aFrame, &h);
+    aFrame->code++;
+
+    std::ofstream out(VRDiagPath("rttcam_force_enable.txt"), std::ios::out | std::ios::trunc);
+
+    RED4ext::ScriptGameInstance gi;
+    RED4ext::Handle<RED4ext::IScriptable> ph;
+    RED4ext::ExecuteGlobalFunction("GetPlayer;GameInstance", &ph, gi);
+    auto* pe = ph ? reinterpret_cast<RED4ext::ent::Entity*>(ph.instance) : nullptr;
+    if (!pe) { if (out) out << "no player\n"; if (aOut) *aOut = -1; return; }
+
+    int32_t count = 0;
+    for (auto& ch : pe->components) {
+        auto* comp = ch.instance;
+        if (!comp) continue;
+        auto* t = comp->GetType();
+        if (!t || !ClassIsA(t, "entRenderToTextureCameraComponent")) continue;
+
+        uintptr_t cp = reinterpret_cast<uintptr_t>(comp);
+        uint64_t flagBefore = *reinterpret_cast<uint64_t*>(cp + 0x88);
+        uint64_t hBefore     = *reinterpret_cast<uint64_t*>(cp + 0x1E8);
+        uint32_t rBefore     = *reinterpret_cast<uint32_t*>(cp + 0x1E0);  // low dword of resref
+
+        // set fields the engine reads when deciding to render the RTT cam
+        if (w > 0) *reinterpret_cast<uint32_t*>(cp + 0x258) = (uint32_t)w;   // resolutionWidth
+        if (h > 0) *reinterpret_cast<uint32_t*>(cp + 0x25c) = (uint32_t)h;   // resolutionHeight
+        *reinterpret_cast<uint32_t*>(cp + 0x290) = 0;                        // renderingMode = Shaded
+        *reinterpret_cast<uint8_t*>(cp + 0x8b)  = 1;                         // isEnabled = true  <-- the lever
+
+        uint64_t flagAfter = *reinterpret_cast<uint64_t*>(cp + 0x88);
+        if (out) out << "comp=0x" << std::hex << cp
+                     << "  +0x88 before=0x" << flagBefore << " after=0x" << flagAfter
+                     << "  +0x1E8(handle)=0x" << hBefore
+                     << "  +0x1E0(resref.lo)=0x" << rBefore << std::dec
+                     << "  res=" << w << "x" << h << "\n";
+        ++count;
+    }
+    if (out) { out << "enabled " << count << " RTT cam(s); poll comp+0x1E8 via live-RPM to see if a handle appears\n"; out.close(); }
+    if (aOut) *aOut = count > 0 ? count : -2;
+}
