+// [option-C enroll search] Decode the texMgr queues, but only keep the RTT/render-output packets
+// we care about (category rva 0x2B89280, tags 0x3133338 / 0x3133418) and dump their `p1` target
+// objects. Goal: identify whether `p1` is the GPU handle, a wrapper object, or another descriptor,
+// and specifically whether it carries a function pointer at +0x98 into the mapped wrapper path.
+static void TexMgrRttTargetsWorker() {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+    auto isReadable = [](uintptr_t a, size_t n) -> bool {
+        if (a < 0x10000 || a > 0x7fffffffffffULL) return false;
+        MEMORY_BASIC_INFORMATION mbi{};
+        if (VirtualQuery(reinterpret_cast<LPCVOID>(a), &mbi, sizeof(mbi)) == 0) return false;
+        if (mbi.State != MEM_COMMIT || (mbi.Protect & PAGE_GUARD)) return false;
+        DWORD prot = mbi.Protect & 0xFF;
+        if (prot == PAGE_NOACCESS) return false;
+        uintptr_t end = reinterpret_cast<uintptr_t>(mbi.BaseAddress) + mbi.RegionSize;
+        return (a + n) <= end;
+    };
+    auto rd64 = [&](uintptr_t a, uintptr_t* v) -> bool {
+        if (!isReadable(a, 8)) return false;
+        __try { *v = *reinterpret_cast<uintptr_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+    auto rd32 = [&](uintptr_t a, uint32_t* v) -> bool {
+        if (!isReadable(a, 4)) return false;
+        __try { *v = *reinterpret_cast<uint32_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+    auto rd16 = [&](uintptr_t a, uint16_t* v) -> bool {
+        if (!isReadable(a, 2)) return false;
+        __try { *v = *reinterpret_cast<uint16_t*>(a); return true; }
+        __except (EXCEPTION_EXECUTE_HANDLER) { return false; }
+    };
+
+    std::ostringstream sb;
+    sb << "exe base=0x" << std::hex << exeBase << std::dec << "\n";
+    uintptr_t renderer = 0, texMgr = 0;
+    if (!rd64(exeBase + 0x3427C00, &renderer) || !renderer) {
+        std::ofstream out(VRDiagPath("texmgr_rtt_targets.txt")); out << sb.str() << "FAIL renderer null\n"; return;
+    }
+    if (!rd64(renderer + 0x70, &texMgr) || !texMgr) {
+        std::ofstream out(VRDiagPath("texmgr_rtt_targets.txt")); out << sb.str() << "FAIL texMgr null\n"; return;
+    }
+    sb << "renderer=0x" << std::hex << renderer << " texMgr=0x" << texMgr << std::dec << "\n";
+
+    const uintptr_t kRttCat = exeBase + 0x2B89280;
+    int found = 0;
+    for (uintptr_t off = 0x20, idx = 0; off <= 0xC38; off += 0x18, ++idx) {
+        uintptr_t cur = 0;
+        if (!rd64(texMgr + off + 8, &cur) || !cur || !isReadable(cur, 0x4010)) continue;
+        uint32_t cursor = 0;
+        if (!rd32(cur + 0x4000, &cursor) || cursor < 0xE || cursor > 0x4000) continue;
+        for (uint32_t pos = 0xE, cmd = 0; pos + 0x22 <= cursor && pos + 0x22 < 0x4000 && cmd < 32; ++cmd) {
+            uint16_t size = 0;
+            uintptr_t tag = 0, p0 = 0, p1 = 0, p2 = 0;
+            if (!rd16(cur + pos, &size) || size < 0x10 || size > 0x800 || pos + size > 0x4000) break;
+            rd64(cur + pos + 0x2, &tag);
+            rd64(cur + pos + 0xA, &p0);
+            rd64(cur + pos + 0x12, &p1);
+            rd64(cur + pos + 0x1A, &p2);
+            long long tagRva = rvaOf(tag);
+            if ((tagRva == 0x3133338 || tagRva == 0x3133418) && p0 == kRttCat) {
+                ++found;
+                sb << "\n[slot " << std::dec << idx << " cmd " << cmd << "] off=0x" << std::hex << off
+                   << " cur=0x" << cur << " pos=0x" << pos << " size=0x" << size
+                   << " tagRva=0x" << tagRva << " p0=0x" << p0 << " p1=0x" << p1 << " p2=0x" << p2 << std::dec << "\n";
+        if (!p1 || !IsReadableRange(p1, 0xA0)) {
+                    sb << "  p1 unreadable/null\n";
+                } else {
+                    for (uintptr_t qoff = 0; qoff <= 0xC0; qoff += 8) {
+                        uintptr_t q = 0;
+                        if (!rd64(p1 + qoff, &q)) break;
+                        sb << "  +0x" << std::hex << qoff << ": 0x" << q;
+                        long long qr = rvaOf(q);
+                        if (qr >= 0) sb << "  (module rva=0x" << qr << ")";
+                        else if (IsReadableRange(q, 8)) {
+                            uintptr_t inner = 0;
+                            if (rd64(q, &inner)) {
+                                long long ir = rvaOf(inner);
+                                if (ir >= 0) sb << "  (heap obj vtRva=0x" << ir << ")";
+                            }
+                        }
+                        sb << std::dec << "\n";
+                    }
+                    uintptr_t fp98 = 0;
+                    if (rd64(p1 + 0x98, &fp98)) {
+                        long long fr = rvaOf(fp98);
+                        sb << "  fp@+0x98=0x" << std::hex << fp98;
+                        if (fr >= 0) sb << " rva=0x" << fr;
+                        sb << std::dec << "\n";
+                    }
+                }
+            }
+            pos += size;
+        }
+    }
+    sb << "\n==== done: " << found << " RTT packets ====\n";
+    std::ofstream out(VRDiagPath("texmgr_rtt_targets.txt"), std::ios::out | std::ios::trunc);
+    if (out.is_open()) out << sb.str();
+}
