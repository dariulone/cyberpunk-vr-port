+DWORD WINAPI M0WatchdogLoop(LPVOID) {
+    uint64_t reportedStuck = 0;
+    for (;;) {
+        Sleep(2000);
+        ID3D12Fence* fence = g_m0CompFence.Get();
+        if (!fence) continue;
+        const uint64_t completed = fence->GetCompletedValue();
+        const uint64_t issued = g_m0CompFenceValue.load(std::memory_order_relaxed);
+        if (issued <= completed) continue;
+        Sleep(2000);
+        const uint64_t completed2 = fence->GetCompletedValue();
+        if (completed2 != completed || g_m0CompFenceValue.load(std::memory_order_relaxed) <= completed2) continue;
+        const uint64_t stuck = completed2 + 1; // first fence value that never completed
+        if (stuck == reportedStuck) continue;
+        reportedStuck = stuck;
+        M0DupRecord rec{}; bool found = false;
+        {
+            std::lock_guard<std::mutex> lock(g_m0RingMutex);
+            for (const M0DupRecord& r : g_m0Ring) {
+                if (r.fence == stuck) { rec = r; found = true; break; }
+            }
+        }
+        if (found) {
+            Log("[M0-HANG] GPU stuck at fence=%llu: frame=%llu ordinal=%u isDup=%d numLists=%u compBarriers=%u hadIndirect=%d (completed=%llu issued=%llu)\n",
+                static_cast<unsigned long long>(stuck),
+                static_cast<unsigned long long>(rec.frame), rec.ordinal, rec.isDup ? 1 : 0,
+                rec.numLists, rec.compBarriers, rec.hadIndirect ? 1 : 0,
+                static_cast<unsigned long long>(completed2),
+                static_cast<unsigned long long>(g_m0CompFenceValue.load(std::memory_order_relaxed)));
+        } else {
+            Log("[M0-HANG] GPU stuck at fence=%llu (ring record evicted; completed=%llu)\n",
+                static_cast<unsigned long long>(stuck), static_cast<unsigned long long>(completed2));
+        }
+    }
+}
