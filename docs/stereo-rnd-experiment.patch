+// [option-C simultaneous] PRODUCER-level call-site double. See forward-decl comment.
+// At siteRva: rcx=[rsi+0x320] (mgr), rdx=lea local (viewSource/out), r8=lea local. 3-arg __fastcall.
+// Trampoline: eye-1 producer call always (direct); when g_dualView armed, count++ and a 2nd call routed
+// through SEH-wrapped Eye2ProducerCall; then jmp back to siteRva+5. Mid-body CALL patch keeps .pdata intact.
+bool InstallProducerCallSiteHook(uintptr_t siteRva) {
+    if (!g_gameModuleBase) { Log("Producer call-site hook: game base unknown\n"); return false; }
+    uint8_t* site = reinterpret_cast<uint8_t*>(g_gameModuleBase + siteRva);
+    if (!IsReadableAddressRange(reinterpret_cast<uintptr_t>(site), 5) || site[0] != 0xE8) {
+        Log("Producer call-site hook: not an E8 call at %p (rva=0x%llX); aborting\n", site,
+            (unsigned long long)siteRva);
+        return false;
+    }
+    const int32_t rel = *reinterpret_cast<int32_t*>(site + 1);
+    const uintptr_t producer = reinterpret_cast<uintptr_t>(site + 5) + rel;
+    if (producer != g_gameModuleBase + 0x293978) {
+        Log("Producer call-site hook: target %p != sub_140293978 (rva=0x%llX); aborting\n",
+            (void*)producer, (unsigned long long)siteRva);
+        return false;
+    }
+    const uintptr_t jmpBack = reinterpret_cast<uintptr_t>(site + 5);
+    void* tramp = AllocateTrampoline(site, 256);
+    if (!tramp) return false;
+    uint8_t* code = static_cast<uint8_t*>(tramp);
+    int pos = 0;
+    auto emit = [&](std::initializer_list<uint8_t> b){ for (uint8_t x : b) code[pos++] = x; };
+
+    emit({0x53,0x56,0x57});                            // push rbx,rsi,rdi   (rsp now 8-aligned)
+    emit({0x48,0x8B,0xD9});                            // mov rbx,rcx
+    emit({0x48,0x8B,0xF2});                            // mov rsi,rdx
+    emit({0x49,0x8B,0xF8});                            // mov rdi,r8
+    // --- eye-1 (always) ---
+    emit({0x48,0x83,0xEC,0x28});                       // sub rsp,0x28
+    emit({0x48,0x8B,0xCB});                            // mov rcx,rbx
+    emit({0x48,0x8B,0xD6});                            // mov rdx,rsi
+    emit({0x4C,0x8B,0xC7});                            // mov r8,rdi
+    WriteMovRaxImm64(code, pos, producer);             // mov rax, sub_140293978
+    emit({0xFF,0xD0});                                 // call rax
+    emit({0x48,0x83,0xC4,0x28});                       // add rsp,0x28
+    // --- armed? ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_dualView)); // mov rax,&flag
+    emit({0x83,0x38,0x00});                            // cmp dword [rax],0
+    emit({0x74,0x37});                                 // je .done (skip 0x37=55B armed block)
+    // --- eye-2 (armed): 2nd producer call via SEH-wrapped Eye2ProducerCall(producer, rcx,rdx,r8) ---
+    WriteMovRaxImm64(code, pos, reinterpret_cast<uintptr_t>(&g_dualViewCount)); // mov rax,&count  (10)
+    emit({0xF0,0xFF,0x00});                            // lock inc dword [rax]                       (3)
+    emit({0x48,0x83,0xEC,0x28});                       // sub rsp,0x28                               (4)
+    WriteMovRaxImm64(code, pos, producer);             // mov rax, producer                          (10)
+    emit({0x48,0x8B,0xC8});                            // mov rcx,rax  (arg1=producer)               (3)
+    emit({0x48,0x8B,0xD3});                            // mov rdx,rbx  (arg2=orig rcx/builder)       (3)
