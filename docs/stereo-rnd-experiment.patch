+// [option-C enroll search] Correct decoder for the texMgr area at +0x20. The previous
+// DumpRenderTexEntries treated texMgr+0x20 as an inline texture list; Ghidra disasm showed it is
+// actually a family of render-command queues. Each 0x18-byte queue slot points at a 0x4010-byte
+// command chunk; helpers append packets as: uint16 size at chunk+pos, qword typeTag at pos+2,
+// payload at pos+0x0A, with the chunk write cursor at chunk+0x4000 and next/free link at +0x4008.
+// This read-only decoder identifies which command tags appear/disappear when inventory preview opens,
+// letting us map preview/enroll to the texMgr wrapper/helper without any code hook.
+static void TexMgrQueuesWorker() {
+    const uintptr_t exeBase = reinterpret_cast<uintptr_t>(GetModuleHandleW(nullptr));
+    auto rvaOf = [&](uintptr_t p) -> long long {
+        if (p < exeBase) return -1;
+        long long r = (long long)(p - exeBase);
+        return (r >= 0 && r < 0x10000000) ? r : -1;
+    };
+    auto rd64 = [&](uintptr_t a, uintptr_t* v) -> bool {
+        if (!IsReadableRange(a, 8)) return false;
+        return SehReadU64(a, v);
+    };
+    auto rd32 = [&](uintptr_t a, uint32_t* v) -> bool {
+        if (!IsReadableRange(a, 4)) return false;
+        return SehReadU32(a, v);
+    };
+    auto rd16 = [&](uintptr_t a, uint16_t* v) -> bool {
+        if (!IsReadableRange(a, 2)) return false;
+        return SehReadU16(a, v);
+    };
+
+    std::ostringstream sb;
+    sb << "exe base=0x" << std::hex << exeBase << std::dec << "\n";
+    uintptr_t renderer = 0, texMgr = 0;
+    if (!rd64(exeBase + 0x3427C00, &renderer) || !renderer) {
+        std::ofstream out(VRDiagPath("texmgr_queues.txt")); out << sb.str() << "FAIL renderer null\n"; return;
+    }
+    if (!rd64(renderer + 0x70, &texMgr) || !texMgr) {
+        std::ofstream out(VRDiagPath("texmgr_queues.txt")); out << sb.str() << "FAIL texMgr null\n"; return;
+    }
+    sb << "renderer=0x" << std::hex << renderer << " texMgr=0x" << texMgr << std::dec << "\n";
+    sb << "queue slots: texMgr+0x20..0xC38 stride 0x18; command chunks cursor@+0x4000 link@+0x4008\n";
+
+    auto dumpChunk = [&](uintptr_t chunk, const char* label) {
+        if (!chunk || !IsReadableRange(chunk, 0x4010)) {
+            sb << "  " << label << "=0x" << std::hex << chunk << std::dec << " <unreadable/null>\n";
+            return;
+        }
+        uint32_t cursor = 0;
+        uintptr_t link = 0;
+        rd32(chunk + 0x4000, &cursor);
+        rd64(chunk + 0x4008, &link);
+        sb << "  " << label << "=0x" << std::hex << chunk << " cursor=0x" << cursor
+           << " link=0x" << link << std::dec << "\n";
+        if (cursor < 0xE || cursor > 0x4000) return;
+
+        // The command stream starts with a 0xE-byte chunk header; helpers initialize cursor to 0xE.
+        uint32_t pos = 0xE;
+        for (int n = 0; n < 20 && pos + 0x0A <= cursor && pos + 0x0A < 0x4000; ++n) {
+            uint16_t size = 0;
+            uintptr_t tag = 0, p0 = 0, p1 = 0, p2 = 0;
+            if (!rd16(chunk + pos, &size) || size < 0x10 || size > 0x800 || pos + size > 0x4000) {
+                sb << "    cmd[" << n << "] pos=0x" << std::hex << pos << " invalid size=0x" << size << std::dec << "\n";
+                break;
+            }
+            rd64(chunk + pos + 0x2, &tag);
+            rd64(chunk + pos + 0xA, &p0);
+            rd64(chunk + pos + 0x12, &p1);
+            rd64(chunk + pos + 0x1A, &p2);
+            long long tagRva = rvaOf(tag);
+            sb << "    cmd[" << n << "] pos=0x" << std::hex << pos << " size=0x" << size
+               << " tag=0x" << tag;
+            if (tagRva >= 0) sb << " rva=0x" << tagRva;
+            sb << " p0=0x" << p0 << " p1=0x" << p1 << " p2=0x" << p2 << std::dec << "\n";
+            pos += size;
+        }
+    };
+
+    int nonEmpty = 0;
+    constexpr uintptr_t kStart = 0x20;
+    constexpr uintptr_t kEnd = 0xC38;
+    constexpr uintptr_t kStride = 0x18;
+    for (uintptr_t off = kStart, idx = 0; off <= kEnd; off += kStride, ++idx) {
+        uintptr_t head = 0, cur = 0, sync = 0;
+        rd64(texMgr + off, &head);
+        rd64(texMgr + off + 8, &cur);
+        rd64(texMgr + off + 16, &sync);
+            if (!head && !cur) continue;
+            ++nonEmpty;
+        sb << "\n[slot " << std::dec << idx << "] texMgr+0x" << std::hex << off
+           << " head=0x" << head << " cur=0x" << cur << " sync=0x" << sync << std::dec << "\n";
+        if (head == cur) {
+            dumpChunk(head, "chunk");
+        } else {
+            dumpChunk(head, "head");
+            dumpChunk(cur, "cur");
+        }
+    }
+    sb << "\n==== done: " << nonEmpty << " non-empty queue slots ====\n";
+    std::ofstream out(VRDiagPath("texmgr_queues.txt"), std::ios::out | std::ios::trunc);
+    if (out.is_open()) out << sb.str();
+}
+
+void DumpTexMgrQueues(RED4ext::IScriptable* aContext, RED4ext::CStackFrame* aFrame, int32_t* aOut, int64_t a4) {
+    RED4EXT_UNUSED_PARAMETER(aContext); RED4EXT_UNUSED_PARAMETER(a4);
+    aFrame->code++;
+    std::thread(&TexMgrQueuesWorker).detach();
+    if (aOut) *aOut = 1;
+}
