+    Log("\n==== VR CRASH HANDLER (code=0x%08lX) ====\n", static_cast<unsigned long>(code));
+    Log("faultAddr=%p where=%s ida=0x%llX rva=0x%llX gameBase=0x%llX\n",
+        reinterpret_cast<void*>(fault), where, ida, rva,
+        static_cast<unsigned long long>(g_gameModuleBase));
+    if (code == EXCEPTION_ACCESS_VIOLATION && info->ExceptionRecord->NumberParameters >= 2) {
+        const ULONG_PTR* p = info->ExceptionRecord->ExceptionInformation;
+        const char* op = p[0] == 0 ? "READ" : (p[0] == 1 ? "WRITE" : (p[0] == 8 ? "EXEC" : "?"));
+        Log("  AV op=%s target=0x%llX\n", op, static_cast<unsigned long long>(p[1]));
+    }
+    uintptr_t sp = info->ContextRecord ? static_cast<uintptr_t>(info->ContextRecord->Rsp) : 0;
+    if (info->ContextRecord) {
