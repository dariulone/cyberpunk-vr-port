+    if (vs) vs->Release(); if (ps) ps->Release(); if (e1) e1->Release(); if (e2) e2->Release();
+    if (FAILED(hpso)) { Log("OpenXRManager: SBS PSO failed hr=0x%08X\n", (unsigned)hpso); return false; }
